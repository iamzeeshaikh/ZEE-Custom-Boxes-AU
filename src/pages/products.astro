---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE } from '../config/site';
import products from '../data/products.json';
import categories from '../data/categories.json';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "All Products", "item": `${SITE.url}/products` },
  ]
};
---

<Layout
  title="All Custom Packaging Products | ZEE Custom Boxes AU"
  description="Browse 373+ premium custom packaging products. Cosmetic boxes, food packaging, gift boxes, retail boxes and more. Free design, fast shipping across Australia."
  canonical={`${SITE.url}/products`}
  schema={breadcrumbSchema}
>

  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">›</span>
        <span aria-current="page">All Products</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="products-hero">
    <div class="container">
      <div class="section-label">Our Complete Range</div>
      <h1>All Custom Packaging Products</h1>
      <div class="gold-divider"></div>
      <p>Discover {products.length}+ premium packaging solutions across {categories.length} categories. Every product includes free design service, no minimum order, and fast Australia-wide delivery.</p>
    </div>
  </section>

  <!-- Categories Filter -->
  <section class="section-sm bg-light">
    <div class="container">
      <div class="cat-filter-label">Browse by Category:</div>
      <div class="cat-filters">
        <a href="/products" class="cat-filter active">All Products ({products.length})</a>
        {categories.map(cat => (
          <a href={`/category/${cat.slug}`} class="cat-filter">{cat.name} ({cat.products.length})</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="section">
    <div class="container">
      <div class="grid-4">
        {products.map((product, i) => (
          <div class="reveal" style={`animation-delay: ${(i % 8) * 0.04}s`}>
            <ProductCard product={product} eager={i < 8} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-light">
    <div class="container text-center">
      <div class="section-label">Can't Find What You Need?</div>
      <h2>Custom Packaging Tailored to You</h2>
      <div class="gold-divider"></div>
      <p style="max-width: 560px; margin: 0 auto 2rem;">Don't see exactly what you're looking for? We create fully bespoke packaging to your specifications. Contact us with your requirements and we'll build the perfect solution.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/request-quote" class="btn btn-primary btn-lg">Request a Custom Quote →</a>
        <a href="/contact" class="btn btn-outline btn-lg">Get in Touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.breadcrumb-bar { background: var(--color-off-white); border-bottom: 1px solid var(--color-border); padding: 0.875rem 0; }

.products-hero {
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  padding: 4rem 0 3rem;
  text-align: center;
}
.products-hero .section-label { color: rgba(255,255,255,0.6); }
.products-hero h1 { color: #fff; font-size: clamp(1.8rem, 3.5vw, 3rem); margin-bottom: 0.5rem; }
.products-hero p { color: rgba(255,255,255,0.75); font-size: 1.05rem; max-width: 600px; margin: 1rem auto 0; }

.cat-filter-label { font-size: 0.85rem; font-weight: 700; color: var(--color-navy); margin-bottom: 0.75rem; }
.cat-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.cat-filter {
  display: inline-block;
  padding: 0.4rem 1rem;
  font-size: 0.8rem;
  font-weight: 600;
  border: 1.5px solid var(--color-border);
  border-radius: 100px;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: all 0.2s;
}
.cat-filter:hover, .cat-filter.active {
  border-color: var(--color-navy);
  background: var(--color-navy);
  color: #fff;
}
</style>
