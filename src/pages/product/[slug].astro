            <div class="preview-badge">
              <span class="preview-dot"></span>
              Live Preview
            </div>
            <div class="preview-stage" id="preview-stage">
              <svg class="preview-box-svg" viewBox="0 0 220 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Packaging preview">
                <defs>
                  <!-- Clip to front-left face -->
                  <clipPath id="clip-front">
                    <polygon points="25,62 110,106 110,166 25,122"/>
                  </clipPath>
                  <!-- Clip to right face -->
                  <clipPath id="clip-right">
                    <polygon points="110,106 195,62 195,122 110,166"/>
                  </clipPath>
                  <!-- Clip to top face -->
                  <clipPath id="clip-top">
                    <polygon points="110,18 195,62 110,106 25,62"/>
                  </clipPath>
                  <linearGradient id="foilGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#ffd700" stop-opacity="0.6"/>
                    <stop offset="50%" stop-color="#fff8dc" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="#ffd700" stop-opacity="0.5"/>
                  </linearGradient>
                  <!-- Darken overlay for right/top faces so artwork reads correctly -->
                  <filter id="darken-right">
                    <feColorMatrix type="matrix" values="0.55 0 0 0 0  0 0.55 0 0 0  0 0 0.55 0 0  0 0 0 1 0"/>
                  </filter>
                </defs>

                <!-- Base faces -->
                <polygon id="box-top"   points="110,18 195,62 110,106 25,62"  fill="#c9a84c" opacity="0.92"/>
                <polygon id="box-left"  points="25,62 110,106 110,166 25,122" fill="#1a3a5c" opacity="0.95"/>
                <polygon id="box-right" points="110,106 195,62 195,122 110,166" fill="#0d2035" opacity="0.95"/>

                <!-- Artwork image on front-left face (hidden until upload) -->
                <image id="artwork-front" href="" x="25" y="62" width="85" height="104"
                  clip-path="url(#clip-front)" preserveAspectRatio="xMidYMid slice"
                  opacity="0" style="transition:opacity 0.4s"/>
                <!-- Darker tinted copy on right face -->
                <image id="artwork-right" href="" x="110" y="62" width="85" height="104"
                  clip-path="url(#clip-right)" preserveAspectRatio="xMidYMid slice"
                  filter="url(#darken-right)" opacity="0" style="transition:opacity 0.4s"/>

                <!-- Edge highlights (rendered on top of artwork) -->
                <polyline points="25,62 110,106 195,62" stroke="rgba(255,255,255,0.25)" stroke-width="1"/>
                <line x1="110" y1="106" x2="110" y2="166" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>

                <!-- Logo placeholder (hidden when artwork loaded) -->
                <text id="logo-placeholder" x="67" y="140" fill="rgba(255,255,255,0.35)" font-size="9" font-family="Georgia,serif" text-anchor="middle">YOUR LOGO</text>

                <!-- Foil shimmer overlay -->
                <polygon id="box-foil" points="110,18 195,62 110,106 25,62" fill="url(#foilGrad)" opacity="0" style="pointer-events:none"/>
              </svg>
              <!-- Non-image file badge (PDF/AI/EPS etc.) -->
              <div class="artwork-file-badge" id="artwork-file-badge" style="display:none">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span id="artwork-file-name">file.pdf</span>
              </div>
              <div class="preview-finish-badges" id="preview-finish-badges"></div>
            </div>
            <div class="preview-caption" id="preview-caption">Select options to preview</div>
          </div>

          <!-- Summary list -->
          <div class="summary-list" id="summary-list">
            {[
              { key:'size',     label:'Size',           val:'Not selected' },
              { key:'material', label:'Material',       val:'Not selected' },
              { key:'printing', label:'Printing',       val:'Not selected' },
              { key:'finish',   label:'Finishes',       val:'None' },
              { key:'qty',      label:'Quantity',       val:'Not selected' },
              { key:'addon',    label:'Add-Ons',        val:'None' },
              { key:'design',   label:'Design Support', val:'Not requested' },
            ].map(row => (
              <div class="summary-row" id={`sum-${row.key}`}>
                <span class="sum-label">{row.label}</span>
                <span class="sum-val" id={`sum-val-${row.key}`}>{row.val}</span>
              </div>
            ))}
          </div>

          <!-- Price estimate -->
          <div class="price-estimate-box" id="price-estimate-box">
            <div class="price-est-label">Estimated Price Range</div>
            <div class="price-est-amount" id="price-est-amount">Select options above</div>
            <div class="price-est-note">Pricing is indicative only. Final quote confirmed after review.</div>
          </div>

          <!-- Trust mini -->
          <div class="cfg-trust-mini">
            {[
              'Free Design Included',
