---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { SITE } from '../../config/site';
import products from '../../data/products.json';
import { buildRichDescription } from '../../utils/richDescription';

export async function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

function catSlug(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();
}

const related = products
  .filter(p => p.slug !== product.slug && p.categories.some((c: string) => product.categories.includes(c)))
  .slice(0, 4);

const primaryCat = product.primaryCategory || product.categories[0];
const primaryCatSlug = primaryCat ? catSlug(primaryCat) : '';

const hasDesc  = Boolean(product.description);
const hasSpecs = Boolean(product.specifications);
const hasFaqs  = Boolean(product.faqs);
const images   = product.images as string[];

const richDescription = buildRichDescription(product, primaryCat, primaryCatSlug, related);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": primaryCat, "item": `${SITE.url}/category/${primaryCatSlug}` },
    { "@type": "ListItem", "position": 3, "name": product.name, "item": `${SITE.url}/product/${product.slug}` },
  ]
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.metaDescription,
  "image": images,
  "brand": { "@type": "Brand", "name": "ZEE Custom Boxes AU" },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "price": "0",
    "priceSpecification": { "@type": "PriceSpecification", "description": "Quote-based pricing" },
    "seller": { "@type": "Organization", "name": SITE.name },
    "availability": "https://schema.org/InStock",
    "areaServed": "AU"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "127",
    "bestRating": "5"
  }
};
---

<Layout
  title={product.seoTitle || `${product.name} | ${SITE.name}`}
  description={product.metaDescription}
  canonical={`${SITE.url}/product/${product.slug}`}
  image={images[0] || '/images/og-default.jpg'}
  schema={[productSchema, breadcrumbSchema]}
>

<!-- ═══════════════════════════════════════════════════════════
     BREADCRUMB
══════════════════════════════════════════════════════════════ -->
<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">›</span>
      {primaryCat && (
        <>
          <a href={`/category/${primaryCatSlug}`}>{primaryCat}</a>
          <span class="sep">›</span>
        </>
      )}
      <span aria-current="page">{product.name}</span>
    </nav>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     PRODUCT HERO — Gallery + Info
══════════════════════════════════════════════════════════════ -->
<section class="product-hero">
  <div class="container">
    <div class="product-layout">

      <!-- ── Gallery ── -->
      <div class="product-gallery">
        <div class="gallery-main-wrap" id="gallery-main-wrap" data-images={JSON.stringify(images)}>
          {images[0] ? (
            <img
              id="main-img"
              src={images[0]}
              alt={`${product.name} - ZEE Custom Boxes AU`}
              width="700" height="580"
              loading="eager" decoding="async"
              class="gallery-main-img"
              onerror="this.src='/images/placeholder.webp'"
            />
          ) : (
            <div class="gallery-placeholder">
              <svg width="80" height="80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24" opacity="0.2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21,15 16,10 5,21"/>
              </svg>
            </div>
          )}
          <!-- Zoom icon -->
          {images[0] && (
            <button class="gallery-zoom-btn" id="open-lightbox" aria-label="View full size">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v6M8 11h6"/>
              </svg>
            </button>
          )}
          <!-- Image counter badge -->
          {images.length > 1 && (
            <div class="gallery-counter" id="gallery-counter">1 / {images.length}</div>
          )}
        </div>

        {images.length > 1 && (
          <div class="gallery-thumbs" id="gallery-thumbs">
            {images.map((img, i) => (
              <button
                class={`gallery-thumb ${i === 0 ? 'active' : ''}`}
                data-src={img}
                data-index={i}
                aria-label={`View image ${i + 1}`}
              >
                <img
                  src={img}
                  alt={`${product.name} view ${i + 1}`}
                  width="120" height="90"
                  loading="lazy" decoding="async"
                  onerror="this.parentElement.style.display='none'"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- ── Info Panel ── -->
      <div class="product-info">

        <!-- Category badges -->
        <div class="product-cats">
          {product.categories.slice(0, 3).map((cat: string) => (
            <a href={`/category/${catSlug(cat)}`} class="product-cat-badge">{cat}</a>
          ))}
        </div>

        <h1 class="product-title">{product.name}</h1>

        <!-- Rating row -->
        <div class="product-rating-row">
          <div class="stars">
            {'★★★★★'.split('').map(() => <span class="star">★</span>)}
          </div>
          <span class="rating-score">4.9</span>
          <span class="rating-sep">·</span>
          <span class="rating-count">127 reviews</span>
          <span class="rating-sep">·</span>
          <span class="in-stock">✓ In Stock</span>
        </div>

        <div class="info-divider"></div>

        <!-- Short description -->
        {product.shortDescription && (
          <div class="product-short-desc prose" set:html={product.shortDescription} />
        )}

        <!-- Trust badges grid -->
        <div class="trust-grid">
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>Free Design Service</strong>
              <span>Expert artwork at no charge</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>No Minimum Order</strong>
              <span>Any quantity, any size</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>Fast Turnaround</strong>
              <span>7–14 business days</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="1" y="3" width="15" height="13" rx="1"/>
                <polygon points="16,8 20,8 23,11 23,16 16,16 16,8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>Nationwide Delivery</strong>
              <span>All cities across Australia</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>Wholesale Pricing</strong>
              <span>Better price as you scale</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div class="trust-text">
              <strong>Quality Guaranteed</strong>
              <span>Premium materials, certified</span>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="product-cta-wrap">
          <a href="#request-quote" class="btn-cta-primary">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
            </svg>
            Request a Free Quote
          </a>
          <a href={`tel:${SITE.phone}`} class="btn-cta-secondary">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            {SITE.phone}
          </a>
        </div>

        <!-- Assurance strip -->
        <div class="assurance-strip">
          <span class="assurance-dot"></span>
          <span>Receive your detailed quote within <strong>24 hours</strong> — no obligation</span>
        </div>

        <!-- Quick Quote Mini Form -->
        <div class="mini-form-wrap">
          <div class="mini-form-header">
            <div class="mini-form-title">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
              Quick Quote — 60 seconds
            </div>
            <span class="mini-form-badge">Free &amp; No Obligation</span>
          </div>
          <form
            class="mini-form"
            data-email-form="Quick Quote"
          >
            <input type="hidden" name="product" value={product.name} />
            <div class="form-error-msg" style="display:none;background:#fef2f2;color:#dc2626;padding:0.6rem 0.9rem;border-radius:6px;font-size:0.82rem;margin-bottom:0.5rem;"></div>

            <div class="mf-row">
              <div class="mf-group">
                <input type="text" name="name" required placeholder="Your Name *" />
              </div>
              <div class="mf-group">
                <input type="email" name="email" required placeholder="Email Address *" />
              </div>
            </div>

            <div class="mf-group">
              <input type="tel" name="phone" placeholder="Phone Number" />
            </div>

            <div class="mf-group">
              <textarea name="message" rows="3" placeholder="Your requirements (size, quantity, material, timeline…)"></textarea>
            </div>

            <div class="mf-group mf-file-group">
              <label class="mf-file-label">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <span id="mf-file-text">Upload Artwork (optional)</span>
                <input type="file" name="artwork" accept=".pdf,.ai,.eps,.psd,.jpg,.jpeg,.png,.svg,.zip" id="mf-artwork" />
              </label>
            </div>

            <button type="submit" class="mf-submit">
              Send My Quote Request
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     TRUST PILLARS STRIP
══════════════════════════════════════════════════════════════ -->
<div class="trust-strip">
  <div class="container">
    <div class="trust-pillars">
      <div class="pillar">
        <svg width="22" height="22" fill="none" stroke="var(--color-gold)" stroke-width="2" viewBox="0 0 24 24">
          <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        <span>Free Professional Design</span>
      </div>
      <div class="pillar-sep"></div>
      <div class="pillar">
        <svg width="22" height="22" fill="none" stroke="var(--color-gold)" stroke-width="2" viewBox="0 0 24 24">
          <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
        </svg>
        <span>No Minimum Order Quantity</span>
      </div>
      <div class="pillar-sep"></div>
      <div class="pillar">
        <svg width="22" height="22" fill="none" stroke="var(--color-gold)" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>7–14 Day Production</span>
      </div>
      <div class="pillar-sep"></div>
      <div class="pillar">
        <svg width="22" height="22" fill="none" stroke="var(--color-gold)" stroke-width="2" viewBox="0 0 24 24">
          <rect x="1" y="3" width="15" height="13" rx="1"/>
          <polygon points="16,8 20,8 23,11 23,16 16,16 16,8"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
        <span>Australia-Wide Shipping</span>
      </div>
      <div class="pillar-sep"></div>
      <div class="pillar">
        <svg width="22" height="22" fill="none" stroke="var(--color-gold)" stroke-width="2" viewBox="0 0 24 24">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Premium Quality Guaranteed</span>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     CONFIGURATOR
══════════════════════════════════════════════════════════════ -->
<section class="configurator-section" id="configurator">
  <div class="container">

    <div class="cfg-header reveal">
      <div class="section-label">Interactive Configurator</div>
      <h2>Customize Your {product.name}</h2>
      <div class="gold-divider"></div>
      <p>Choose your packaging options below and receive a live price estimate with your selections.</p>
    </div>

    <div class="cfg-layout">

      <!-- ── LEFT: Options ── -->
      <div class="cfg-options">

        <!-- STEP 1: Size -->
        <div class="cfg-step" id="cfg-step-size">
          <div class="cfg-step-label">
            <span class="cfg-step-num">1</span>
            <h3>Select Size</h3>
          </div>
          <div class="cfg-cards" id="size-cards">
            {[
              { id:'xs',  label:'Extra Small', dims:'5 × 5 × 3 cm' },
              { id:'sm',  label:'Small',        dims:'10 × 8 × 4 cm' },
              { id:'md',  label:'Medium',       dims:'15 × 12 × 6 cm' },
              { id:'lg',  label:'Large',        dims:'20 × 15 × 10 cm' },
              { id:'xl',  label:'Extra Large',  dims:'30 × 25 × 15 cm' },
              { id:'cus', label:'Custom Size',  dims:'Enter below ↓'  },
            ].map(s => (
              <button class="cfg-card" data-group="size" data-val={s.id} aria-pressed="false">
                <span class="cfg-card-title">{s.label}</span>
                <span class="cfg-card-sub">{s.dims}</span>
              </button>
            ))}
          </div>
          <div class="custom-dims" id="custom-dims">
            <div class="dims-row">
              <div class="dim-group">
                <label>Length</label>
                <input type="number" id="dim-l" placeholder="0" min="1" max="9999" />
              </div>
              <span class="dim-sep">×</span>
              <div class="dim-group">
                <label>Width</label>
                <input type="number" id="dim-w" placeholder="0" min="1" max="9999" />
              </div>
              <span class="dim-sep">×</span>
              <div class="dim-group">
                <label>Height</label>
                <input type="number" id="dim-h" placeholder="0" min="1" max="9999" />
              </div>
              <select id="dim-unit" class="dim-unit">
                <option value="cm">cm</option>
                <option value="mm">mm</option>
                <option value="in">in</option>
              </select>
            </div>
          </div>
        </div>

        <!-- STEP 2: Material -->
        <div class="cfg-step">
          <div class="cfg-step-label">
            <span class="cfg-step-num">2</span>
            <h3>Select Material</h3>
          </div>
          <div class="cfg-cards" id="material-cards">
            {[
              { id:'cardboard',   label:'Cardboard',   sub:'300–450gsm',         icon:'📦', color:'#e8dcc8' },
              { id:'kraft',       label:'Kraft',        sub:'Natural brown paper', icon:'🌿', color:'#c9a87a' },
              { id:'corrugated',  label:'Corrugated',   sub:'Heavy-duty shipping', icon:'🏗️', color:'#d4b896' },
              { id:'rigid',       label:'Rigid Board',  sub:'Premium luxury feel', icon:'💎', color:'#8090a0' },
              { id:'eco',         label:'Eco-Friendly', sub:'FSC certified',       icon:'♻️', color:'#a8c080' },
            ].map(m => (
              <button class="cfg-card cfg-card-mat" data-group="material" data-val={m.id} data-color={m.color} aria-pressed="false">
                <span class="cfg-mat-icon">{m.icon}</span>
                <span class="cfg-card-title">{m.label}</span>
                <span class="cfg-card-sub">{m.sub}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- STEP 3: Printing -->
        <div class="cfg-step">
          <div class="cfg-step-label">
            <span class="cfg-step-num">3</span>
            <h3>Printing Options <span class="cfg-multi-hint">Select all that apply</span></h3>
          </div>
          <div class="cfg-cards cfg-multi" id="printing-cards">
            {[
              { id:'none',     label:'No Printing',       sub:'Plain / unprinted' },
              { id:'cmyk',     label:'Full Colour CMYK',  sub:'Standard 4-colour' },
              { id:'pms',      label:'PMS Spot Colours',  sub:'Pantone matched' },
              { id:'inside',   label:'Inside Printing',   sub:'Interior design' },
              { id:'outside',  label:'Outside Printing',  sub:'Exterior design' },
              { id:'both',     label:'Both Sides',        sub:'In & out printed' },
            ].map(p => (
              <button class="cfg-card" data-group="printing" data-val={p.id} aria-pressed="false">
                <span class="cfg-card-title">{p.label}</span>
                <span class="cfg-card-sub">{p.sub}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- STEP 4: Finishes -->
        <div class="cfg-step">
          <div class="cfg-step-label">
            <span class="cfg-step-num">4</span>
            <h3>Select Finishes <span class="cfg-multi-hint">Select all that apply</span></h3>
          </div>
          <div class="cfg-cards cfg-multi" id="finish-cards">
            {[
              { id:'gloss',   label:'Gloss Lamination', sub:'High shine surface' },
              { id:'matte',   label:'Matte Lamination', sub:'Smooth satin look' },
              { id:'spotUV',  label:'Spot UV',           sub:'Selective high gloss' },
              { id:'goldFoil',label:'Gold Foil',         sub:'Luxury metallic gold' },
              { id:'silvFoil',label:'Silver Foil',       sub:'Metallic silver shine' },
              { id:'emboss',  label:'Embossing',         sub:'Raised texture' },
              { id:'deboss',  label:'Debossing',         sub:'Pressed-in texture' },
              { id:'softTch', label:'Soft-Touch',        sub:'Velvet-like finish' },
            ].map(f => (
              <button class="cfg-card" data-group="finish" data-val={f.id} aria-pressed="false">
                <span class="cfg-card-title">{f.label}</span>
                <span class="cfg-card-sub">{f.sub}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- STEP 5: Quantity -->
        <div class="cfg-step">
          <div class="cfg-step-label">
            <span class="cfg-step-num">5</span>
            <h3>Select Quantity</h3>
          </div>
          <div class="qty-presets" id="qty-cards">
            {[100, 250, 500, 1000, 2500, 5000, 10000].map(q => (
              <button class="qty-btn" data-group="qty" data-val={q} aria-pressed="false">
                {q.toLocaleString()}{q === 10000 ? '+' : ''}
              </button>
            ))}
          </div>
          <div class="custom-qty-wrap">
            <label class="custom-qty-label">Or enter custom quantity:</label>
            <input type="number" id="custom-qty" placeholder="e.g. 750" min="1" max="999999" class="custom-qty-input" />
          </div>
        </div>

        <!-- STEP 6: Add-Ons -->
        <div class="cfg-step">
          <div class="cfg-step-label">
            <span class="cfg-step-num">6</span>
            <h3>Optional Add-Ons <span class="cfg-multi-hint">Select all that apply</span></h3>
          </div>
          <div class="cfg-cards cfg-multi" id="addon-cards">
            {[
              { id:'insert',   label:'Inserts',          sub:'Custom tray or foam' },
              { id:'window',   label:'Window Cut',        sub:'Transparent panel' },
              { id:'ribbon',   label:'Ribbon Closure',   sub:'Silk ribbon & bow' },
              { id:'magnetic', label:'Magnetic Closure', sub:'Premium snap close' },
              { id:'handles',  label:'Handles',          sub:'Die-cut carry handles' },
              { id:'sleeves',  label:'Sleeves',          sub:'Outer paper sleeve' },
            ].map(a => (
              <button class="cfg-card" data-group="addon" data-val={a.id} aria-pressed="false">
                <span class="cfg-card-title">{a.label}</span>
                <span class="cfg-card-sub">{a.sub}</span>
              </button>
            ))}
