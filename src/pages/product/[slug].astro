<!-- ═══════════════════════════════════════════════════════════
     QUOTE FORM — Premium inline version
══════════════════════════════════════════════════════════════ -->
<section class="quote-section-premium" id="request-quote">
  <div class="container">
    <div class="quote-layout">

      <!-- Left: Content -->
      <div class="quote-left reveal">
        <div class="section-label" style="color:var(--color-gold)">Get Started Today</div>
        <h2>Request Your Free Quote for {product.name}</h2>
        <div class="gold-divider gold-divider-left"></div>
        <p>Tell us about your packaging requirements and our team will respond with detailed pricing, material options, and design recommendations — all within 24 hours.</p>

        <div class="quote-trust-list">
          {[
            'Free professional design included',
            'No minimum order quantity',
            'Detailed quote within 24 hours',
            'No obligation whatsoever',
            'Australia-wide delivery available',
          ].map(item => (
            <div class="quote-trust-item">
              <span class="quote-check">✓</span>
              <span>{item}</span>
            </div>
          ))}
        </div>

        <div class="quote-contact-block">
          <div class="qc-label">Prefer to speak with us?</div>
          <a href={`tel:${SITE.phone}`} class="qc-phone">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            {SITE.phone}
          </a>
          <div class="qc-email-wrap">
            <a href={`mailto:${SITE.email}`} class="qc-email">{SITE.email}</a>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="quote-right reveal">
        <div class="quote-form-card">
          <div class="qfc-header">
            <div class="qfc-badge">Free &amp; No Obligation</div>
            <h3>Request a Quote</h3>
            <p>We'll respond within 24 business hours</p>
          </div>
          <form class="premium-form" data-email-form="Product Quote Request">
            <input type="hidden" name="product" value={product.name} />
            <div class="form-error-msg" style="display:none;background:#fef2f2;color:#dc2626;padding:0.75rem 1rem;border-radius:6px;font-size:0.875rem;margin-bottom:0.5rem;"></div>
            <div class="pf-row">
              <div class="pf-group">
                <label>First Name <span class="req">*</span></label>
                <input type="text" name="firstName" required placeholder="John" />
              </div>
              <div class="pf-group">
                <label>Last Name <span class="req">*</span></label>
                <input type="text" name="lastName" required placeholder="Smith" />
              </div>
            </div>
            <div class="pf-group">
              <label>Email Address <span class="req">*</span></label>
              <input type="email" name="email" required placeholder="john@company.com" />
            </div>
            <div class="pf-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" placeholder="+61 4XX XXX XXX" />
            </div>
            <div class="pf-row">
              <div class="pf-group">
                <label>Quantity <span class="req">*</span></label>
                <input type="text" name="quantity" required placeholder="e.g. 500 units" />
              </div>
              <div class="pf-group">
                <label>Dimensions</label>
                <input type="text" name="size" placeholder="L × W × H cm" />
              </div>
            </div>
            <div class="pf-group">
              <label>Additional Requirements</label>
              <textarea name="message" rows="4" placeholder="Material preference, printing/finishing, timeline, special requirements..."></textarea>
            </div>
            <button type="submit" class="pf-submit">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
              </svg>
              Send My Free Quote Request
            </button>
            <p class="pf-note">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              Your information is safe and never shared with third parties.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

