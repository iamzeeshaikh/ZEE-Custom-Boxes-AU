<!-- ═══════════════════════════════════════════════════════════
     LIGHTBOX OVERLAY
══════════════════════════════════════════════════════════════ -->
{images.length > 0 && (
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image gallery" aria-hidden="true">
    <div class="lightbox-overlay" id="lb-overlay"></div>
    <div class="lightbox-content">
      <button class="lb-close" id="lb-close" aria-label="Close">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <button class="lb-prev" id="lb-prev" aria-label="Previous image">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <img id="lb-img" src={images[0]} alt={product.name} loading="lazy" onerror="this.src='/images/placeholder.webp'" />
      <button class="lb-next" id="lb-next" aria-label="Next image">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
      <div class="lb-counter" id="lb-counter">1 / {images.length}</div>
    </div>
  </div>
)}

</Layout>

<!-- ═══════════════════════════════════════════════════════════
     STYLES
══════════════════════════════════════════════════════════════ -->
<style>
/* ── Breadcrumb ── */
.breadcrumb-bar {
  background: var(--color-off-white);
  border-bottom: 1px solid var(--color-border);
  padding: 0.875rem 0;
}

/* ── Hero ── */
.product-hero {
  padding: 3rem 0 3.5rem;
  background: #fff;
}

.product-layout {
  display: grid;
  grid-template-columns: 58% 1fr;
  gap: 3.5rem;
  align-items: start;
}

/* Gallery */
.product-gallery { position: sticky; top: 1.5rem; }

.gallery-main-wrap {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-off-white);
  border: 1px solid var(--color-border);
  aspect-ratio: 1 / 1;
  cursor: zoom-in;
}

.gallery-main-wrap:hover .gallery-main-img { transform: scale(1.06); }

.gallery-main-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease;
}

.gallery-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: var(--color-text-muted);
}

.gallery-zoom-btn {
  position: absolute;
  top: 1rem; right: 1rem;
  width: 40px; height: 40px;
  background: rgba(255,255,255,0.92);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: var(--color-navy);
  transition: all 0.2s;
  backdrop-filter: blur(4px);
  z-index: 2;
}
.gallery-zoom-btn:hover { background: var(--color-gold); color: #fff; border-color: var(--color-gold); }

.gallery-counter {
  position: absolute;
  bottom: 1rem; right: 1rem;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 0.3rem 0.65rem;
  border-radius: 100px;
  backdrop-filter: blur(4px);
  letter-spacing: 0.05em;
  z-index: 2;
  pointer-events: none;
}

.gallery-thumbs {
  display: flex;
  gap: 0.75rem;
  margin-top: 1rem;
  flex-wrap: wrap;
}

.gallery-thumb {
  width: 78px; height: 72px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 2.5px solid var(--color-border);
  cursor: pointer;
  padding: 0; background: none;
  transition: all 0.2s;
  flex-shrink: 0;
}
.gallery-thumb:hover { border-color: var(--color-gold); box-shadow: 0 4px 12px rgba(201,168,76,0.3); }
.gallery-thumb.active { border-color: var(--color-gold); box-shadow: 0 4px 12px rgba(201,168,76,0.4); }
.gallery-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Product Info */
.product-info { padding-top: 0.25rem; }

.product-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 0.875rem;
}

.product-cat-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.875rem;
  background: var(--color-gold-pale);
  color: var(--color-gold);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 100px;
  text-decoration: none;
  transition: all 0.2s;
  border: 1px solid rgba(201,168,76,0.3);
  white-space: nowrap;
}
.product-cat-badge:hover { background: var(--color-gold); color: #fff; border-color: var(--color-gold); }

.product-title {
  font-size: clamp(1.5rem, 2.2vw, 2.1rem);
  color: var(--color-navy);
  line-height: 1.2;
  margin: 0.5rem 0 1rem;
  font-weight: 700;
}

/* Rating row */
.product-rating-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.stars { display: flex; gap: 2px; }
.star { color: var(--color-gold); font-size: 1rem; }

.rating-score { font-weight: 700; font-size: 0.9rem; color: var(--color-navy); }
.rating-sep { color: var(--color-border); }
.rating-count { font-size: 0.85rem; color: var(--color-text-muted); text-decoration: underline; cursor: pointer; }
.in-stock { font-size: 0.8rem; font-weight: 700; color: #22c55e; letter-spacing: 0.03em; }

.info-divider { height: 1px; background: var(--color-border); margin: 1rem 0 1.25rem; }

.product-short-desc { margin-bottom: 1.5rem; }
.product-short-desc :global(p) { font-size: 0.95rem; line-height: 1.75; color: var(--color-text-muted); }

/* Trust grid */
.trust-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.875rem;
  margin-bottom: 2rem;
  background: var(--color-off-white);
  border-radius: var(--radius-md);
  padding: 1.25rem;
  border: 1px solid var(--color-border-light);
}

.trust-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}

.trust-icon {
  width: 38px; height: 38px;
  background: var(--color-gold-pale);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  color: var(--color-gold);
}

.trust-text {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
}
.trust-text strong {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--color-navy);
  line-height: 1.3;
}
.trust-text span {
  font-size: 0.72rem;
  color: var(--color-text-muted);
  line-height: 1.3;
}

/* CTAs */
.product-cta-wrap {
  display: flex;
  gap: 0.875rem;
  margin-bottom: 1.25rem;
  flex-wrap: nowrap;
  align-items: stretch;
}

.btn-cta-primary {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.75rem;
  background: var(--color-red);
  color: #fff;
  font-weight: 700;
  font-size: 0.95rem;
  border-radius: var(--radius-sm);
  border: 2px solid var(--color-red);
  text-decoration: none;
  transition: all var(--transition);
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.btn-cta-primary:hover {
  background: var(--color-red-dark);
  border-color: var(--color-red-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(229,57,53,0.35);
}

.btn-cta-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.25rem;
  background: transparent;
  color: var(--color-navy);
  font-weight: 600;
  font-size: 0.9rem;
  border-radius: var(--radius-sm);
  border: 2px solid var(--color-border);
  text-decoration: none;
  transition: all var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
}
.btn-cta-secondary:hover {
  border-color: var(--color-navy);
  background: var(--color-navy);
  color: #fff;
}

.assurance-strip {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
  padding: 0.75rem 1rem;
  background: #f0fdf4;
  border-radius: var(--radius-sm);
  border: 1px solid #bbf7d0;
}

.assurance-dot {
  width: 8px; height: 8px;
  background: #22c55e;
  border-radius: 50%;
  flex-shrink: 0;
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(0.85); }
}

.assurance-strip strong { color: var(--color-navy); }

/* ── Mini Quote Form ── */
.mini-form-wrap {
  margin-top: 1.5rem;
  background: var(--color-off-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.mini-form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.875rem 1.25rem;
  background: var(--color-navy);
  gap: 0.75rem;
}

.mini-form-title {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.02em;
}
.mini-form-title svg { color: var(--color-gold); flex-shrink: 0; }

.mini-form-badge {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-navy-dark);
  background: var(--color-gold);
  padding: 0.2rem 0.6rem;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}

.mini-form {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.mf-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}

.mf-group {
  display: flex;
  flex-direction: column;
}

.mf-group input,
.mf-group textarea {
  padding: 0.65rem 0.875rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--color-text);
  background: #fff;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  width: 100%;
}
.mf-group input::placeholder,
.mf-group textarea::placeholder { color: var(--color-text-muted); font-size: 0.82rem; }
.mf-group input:focus,
.mf-group textarea:focus {
  border-color: var(--color-navy);
  box-shadow: 0 0 0 3px rgba(26,58,92,0.08);
}
.mf-group textarea { resize: vertical; min-height: 80px; }

/* File upload */
.mf-file-group { }

.mf-file-label {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.65rem 0.875rem;
  border: 1.5px dashed var(--color-border);
  border-radius: var(--radius-sm);
  background: #fff;
  cursor: pointer;
  font-size: 0.82rem;
  color: var(--color-text-muted);
  transition: all 0.2s;
  width: 100%;
}
.mf-file-label:hover {
  border-color: var(--color-gold);
  color: var(--color-navy);
  background: var(--color-gold-pale);
}
.mf-file-label svg { color: var(--color-gold); flex-shrink: 0; }
.mf-file-label input[type="file"] { display: none; }

#mf-file-text { flex: 1; }

.mf-submit {
  width: 100%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  background: var(--color-red);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all var(--transition);
}
.mf-submit:hover {
  background: var(--color-red-dark);
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(229,57,53,0.35);
}

/* ── Trust Strip ── */
.trust-strip {
  background: var(--color-navy-dark);
  padding: 1.25rem 0;
  border-top: 3px solid var(--color-red);
}

.trust-pillars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}

.pillar {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.5rem 1.75rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(255,255,255,0.88);
  letter-spacing: 0.02em;
  white-space: nowrap;
}

.pillar-sep {
  width: 1px;
  height: 28px;
  background: rgba(255,255,255,0.12);
  flex-shrink: 0;
}

/* ── Tabs Section ── */
.tabs-section {
  padding: 4.5rem 0;
  background: var(--color-off-white);
}

.tabs-card {
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: 0 4px 32px rgba(0,0,0,0.07);
  overflow: hidden;
  border: 1px solid var(--color-border);
}

.tabs-nav {
  display: flex;
  padding: 0 2rem;
  border-bottom: 2px solid var(--color-border);
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
}
.tabs-nav::-webkit-scrollbar { display: none; }

.tab-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1.125rem 1.5rem;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-muted);
  transition: all 0.2s;
  margin-bottom: -2px;
  white-space: nowrap;
  flex-shrink: 0;
}
.tab-pill svg { opacity: 0.6; transition: opacity 0.2s; }
.tab-pill:hover { color: var(--color-navy); }
.tab-pill:hover svg { opacity: 1; }
.tab-pill.active { color: var(--color-navy); border-bottom-color: var(--color-gold); }
.tab-pill.active svg { opacity: 1; color: var(--color-gold); }

.tab-panel {
  padding: 2.5rem 2.5rem 3rem;
  display: none;
  animation: fadeIn 0.25s ease;
}
.tab-panel.active { display: block; }

.tab-prose :global(p) { font-size: 1rem; line-height: 1.85; color: var(--color-text-muted); margin-bottom: 1.1rem; }
.tab-prose :global(h2), .tab-prose :global(h3) { color: var(--color-navy); margin-top: 2rem; margin-bottom: 0.75rem; }
.tab-prose :global(ul), .tab-prose :global(ol) { margin: 1rem 0 1rem 1.5rem; }
.tab-prose :global(li) { margin-bottom: 0.4rem; color: var(--color-text-muted); }

/* Rich description styles */
.rich-desc :global(h2) {
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--color-navy);
  margin-top: 2.25rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--color-border);
}
.rich-desc :global(h3) {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-navy);
  margin-top: 1.5rem;
  margin-bottom: 0.5rem;
}
.rich-desc :global(ol) {
  margin: 1rem 0 1.5rem 1.5rem;
  counter-reset: none;
}
.rich-desc :global(ol li) {
  margin-bottom: 0.75rem;
  line-height: 1.75;
  color: var(--color-text-muted);
}
.rich-desc :global(ul li) {
  margin-bottom: 0.6rem;
  line-height: 1.75;
  list-style: none;
  padding-left: 0;
}
.rich-desc :global(ul) { list-style: none; margin-left: 0; padding: 0; }
.rich-desc :global(ul li)::before {
  content: '✓';
  color: var(--color-gold);
  font-weight: 700;
  margin-right: 0.6rem;
}
.rich-desc :global(strong) { color: var(--color-navy); font-weight: 700; }

/* Brand-red internal links */
:global(.desc-link) {
  color: var(--color-red);
  font-weight: 600;
  text-decoration: none;
  border-bottom: 1px solid rgba(229,57,53,0.3);
  transition: color 0.2s, border-color 0.2s;
}
:global(.desc-link:hover) {
  color: #b71c1c;
  border-bottom-color: #b71c1c;
}

/* Rich specs table */
.rich-desc :global(.rich-table-wrap) { overflow-x: auto; margin: 1.5rem 0 2rem; }
.rich-desc :global(.rich-specs-table),
.rich-desc :global(.rich-table-wrap table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
}
.rich-desc :global(.rich-specs-table th),
.rich-desc :global(.rich-table-wrap th) {
  background: var(--color-navy);
  color: #fff;
  padding: 0.65rem 1rem;
  text-align: left;
  font-weight: 700;
  font-size: 0.85rem;
  width: 32%;
}
.rich-desc :global(.rich-specs-table td),
.rich-desc :global(.rich-table-wrap td) {
  padding: 0.65rem 1rem;
  border: 1px solid var(--color-border);
  color: var(--color-text);
  line-height: 1.6;
  vertical-align: top;
}
.rich-desc :global(.rich-table-wrap tr:nth-child(even) td) {
  background: var(--color-off-white);
}

/* Specifications table styling */
.specs-table-wrap :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.specs-table-wrap :global(thead tr) { background: var(--color-navy); }
.specs-table-wrap :global(th) {
  padding: 1rem 1.25rem;
  text-align: left;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.9);
  font-family: var(--font-body);
}
.specs-table-wrap :global(td) {
  padding: 0.875rem 1.25rem;
  border-bottom: 1px solid var(--color-border-light);
  color: var(--color-text-muted);
  vertical-align: top;
  line-height: 1.6;
}
.specs-table-wrap :global(tr:nth-child(even) td) { background: var(--color-off-white); }
.specs-table-wrap :global(tr:last-child td) { border-bottom: none; }
.specs-table-wrap :global(td:first-child) { font-weight: 600; color: var(--color-navy); white-space: nowrap; }

/* Artwork Guide */
.artwork-guide { display: flex; flex-direction: column; gap: 2rem; }
.artwork-intro h3 { margin-bottom: 0.5rem; }
.artwork-intro p { color: var(--color-text-muted); }

.artwork-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
}

.artwork-card {
  background: var(--color-off-white);
  border-radius: var(--radius-md);
  padding: 1.5rem;
  border: 1px solid var(--color-border);
  transition: all var(--transition);
}
.artwork-card:hover { border-color: var(--color-gold); box-shadow: var(--shadow-md); }

.artwork-card-icon {
  width: 44px; height: 44px;
  background: var(--color-navy);
  color: var(--color-gold);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1rem;
}

.artwork-card h4 {
  font-size: 0.95rem;
  font-family: var(--font-body);
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: 0.75rem;
}

.artwork-card ul {
  list-style: none;
  padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 0.35rem;
}
.artwork-card li {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  padding-left: 1rem;
  position: relative;
}
.artwork-card li::before {
  content: '→';
  position: absolute; left: 0;
  color: var(--color-gold);
  font-size: 0.75rem;
}

.artwork-cta {
  background: var(--color-gold-pale);
  border-radius: var(--radius-md);
  padding: 1.25rem 1.5rem;
  border: 1px solid rgba(201,168,76,0.3);
}
.artwork-cta p { margin: 0; color: var(--color-navy); font-weight: 500; }
.artwork-cta a { color: var(--color-red); font-weight: 700; text-decoration: underline; }

/* Premium FAQ accordion */
.faq-list { display: flex; flex-direction: column; gap: 0; }

.faq-item-premium {
  border-bottom: 1px solid var(--color-border);
}
.faq-item-premium:first-child { border-top: 1px solid var(--color-border); }

.faq-q-btn {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  width: 100%;
  text-align: left;
  padding: 1.25rem 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--font-body);
  transition: all 0.2s;
}
.faq-q-btn:hover .faq-q-text { color: var(--color-gold); }

.faq-num {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-gold);
  opacity: 0.5;
  flex-shrink: 0;
  min-width: 2rem;
  transition: opacity 0.2s;
}
.faq-q-btn:hover .faq-num, .faq-item-premium.open .faq-num { opacity: 1; }

.faq-q-text {
  flex: 1;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-navy);
  line-height: 1.4;
  transition: color 0.2s;
}

.faq-chevron {
  flex-shrink: 0;
  color: var(--color-text-muted);
  transition: transform 0.3s ease;
}
.faq-item-premium.open .faq-chevron { transform: rotate(180deg); color: var(--color-gold); }

.faq-a-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease, padding 0.35s ease;
  padding: 0 0 0 3.25rem;
}
.faq-item-premium.open .faq-a-panel { max-height: 300px; padding: 0 0 1.5rem 3.25rem; }

.faq-a-text {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--color-text-muted);
  margin: 0;
}

/* ── Why Section ── */
.why-section { padding: 5rem 0; background: var(--color-off-white); }

.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.why-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 2rem;
  border: 1px solid var(--color-border);
  transition: all var(--transition);
}
.why-card:hover {
  border-color: var(--color-gold);
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.why-icon {
  width: 56px; height: 56px;
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  color: var(--color-gold);
  border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.25rem;
}

.why-card h3 {
  font-size: 1.05rem;
  font-family: var(--font-body);
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: 0.625rem;
}
.why-card p { font-size: 0.9rem; line-height: 1.7; margin: 0; }

/* ── Process Section ── */
.process-section { padding: 5rem 0; background: #fff; }

.process-steps {
  display: flex;
  align-items: flex-start;
  gap: 0;
  margin-top: 1rem;
}

.process-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 1rem;
}

.step-number {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 700;
  color: var(--color-gold);
  opacity: 0.25;
  line-height: 1;
  margin-bottom: -0.5rem;
}

.step-icon {
  width: 64px; height: 64px;
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  color: var(--color-gold);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1rem;
  box-shadow: 0 8px 20px rgba(13,32,53,0.25);
}

.process-step h4 {
  font-size: 1rem;
  font-family: var(--font-body);
  font-weight: 700;
  color: var(--color-navy);
  margin-bottom: 0.5rem;
}
.process-step p { font-size: 0.85rem; line-height: 1.65; color: var(--color-text-muted); margin: 0; }

.process-connector {
  flex-shrink: 0;
  width: 3rem;
  height: 2px;
  background: linear-gradient(90deg, var(--color-gold) 0%, rgba(201,168,76,0.3) 100%);
  margin-top: 3.75rem;
}

/* ── Testimonials ── */
.testimonials-section { padding: 5rem 0; background: var(--color-navy-dark); }
.testimonials-section .section-label { color: var(--color-gold); }
.testimonials-section .section-header h2 { color: #fff; }
.testimonials-section .section-header p { color: rgba(255,255,255,0.65); }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.testimonial-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-md);
  padding: 2rem;
  transition: all var(--transition);
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.testimonial-card:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(201,168,76,0.4);
  transform: translateY(-4px);
}

.testimonial-quote-icon { opacity: 0.7; }
.testimonial-stars { color: var(--color-gold); letter-spacing: 2px; font-size: 0.9rem; }

.testimonial-text {
  font-size: 0.9rem;
  line-height: 1.8;
  color: rgba(255,255,255,0.8);
  flex: 1;
  margin: 0;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.testimonial-avatar {
  width: 42px; height: 42px;
  background: linear-gradient(135deg, var(--color-gold) 0%, var(--color-gold-light) 100%);
  color: var(--color-navy-dark);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800;
  font-size: 0.8rem;
  flex-shrink: 0;
}

.testimonial-name {
  font-weight: 700;
  font-size: 0.875rem;
  color: #fff;
  margin-bottom: 0.15rem;
}
.testimonial-role { font-size: 0.75rem; color: rgba(255,255,255,0.5); }

/* Aggregate rating */
.aggregate-rating {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-md);
  padding: 2rem;
  display: flex;
  align-items: center;
  gap: 3rem;
  max-width: 640px;
  margin: 0 auto;
}

.agg-score {
  font-family: var(--font-display);
  font-size: 4rem;
  font-weight: 700;
  color: var(--color-gold);
  line-height: 1;
  flex-shrink: 0;
}

.agg-details { flex: 1; }
.agg-stars { color: var(--color-gold); letter-spacing: 3px; margin-bottom: 0.25rem; }
.agg-label { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 1rem; }
.agg-label strong { color: rgba(255,255,255,0.9); }

.agg-bars { display: flex; flex-direction: column; gap: 0.35rem; }
.agg-bar-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.6);
}
.agg-bar-row span:first-child { width: 2rem; text-align: right; flex-shrink: 0; }
.agg-bar-row span:last-child { width: 2.5rem; flex-shrink: 0; }

.agg-bar {
  flex: 1;
  height: 6px;
  background: rgba(255,255,255,0.1);
  border-radius: 100px;
  overflow: hidden;
}
.agg-bar-fill {
  height: 100%;
  background: var(--color-gold);
  border-radius: 100px;
}

/* ── Premium Quote Form ── */
.quote-section-premium {
  padding: 6rem 0;
  background: linear-gradient(135deg, var(--color-navy-dark) 0%, var(--color-navy) 100%);
  position: relative;
  overflow: hidden;
}
.quote-section-premium::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.quote-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}

.quote-left h2 { color: #fff; margin-bottom: 0.5rem; }
.quote-left p { color: rgba(255,255,255,0.7); font-size: 1rem; margin-bottom: 0; }

.quote-trust-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin: 1.75rem 0;
}

.quote-trust-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.8);
}

.quote-check {
  width: 22px; height: 22px;
  background: var(--color-gold);
  color: var(--color-navy-dark);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem;
  font-weight: 800;
  flex-shrink: 0;
}

.quote-contact-block {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 1.5rem;
}
.qc-label { font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; }
.qc-phone {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-gold);
  text-decoration: none;
  transition: color 0.2s;
}
.qc-phone:hover { color: var(--color-gold-light); }
.qc-email-wrap { margin-top: 0.5rem; }
.qc-email { font-size: 0.875rem; color: rgba(255,255,255,0.55); text-decoration: none; transition: color 0.2s; }
.qc-email:hover { color: rgba(255,255,255,0.9); }

/* Form card */
.quote-form-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

.qfc-header { margin-bottom: 1.75rem; }

.qfc-badge {
  display: inline-block;
  background: var(--color-gold-pale);
  color: var(--color-gold);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.875rem;
  border-radius: 100px;
  margin-bottom: 0.75rem;
}

.qfc-header h3 {
  font-size: 1.4rem;
  font-family: var(--font-display);
  color: var(--color-navy);
  margin-bottom: 0.35rem;
}
.qfc-header p { font-size: 0.85rem; color: var(--color-text-muted); margin: 0; }

.premium-form { display: flex; flex-direction: column; gap: 1.1rem; }
.pf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

.pf-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.pf-group label {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-navy);
}

.req { color: var(--color-red); }

.pf-group input,
.pf-group textarea {
  padding: 0.8rem 1rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--color-text);
  transition: all 0.2s;
  outline: none;
  background: #fafafa;
}
.pf-group input:focus,
.pf-group textarea:focus {
  border-color: var(--color-navy);
  background: #fff;
  box-shadow: 0 0 0 3px rgba(26,58,92,0.08);
}
.pf-group textarea { resize: vertical; min-height: 100px; }

.pf-submit {
  width: 100%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1.05rem 2rem;
  background: var(--color-red);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all var(--transition);
  margin-top: 0.25rem;
}
.pf-submit:hover {
  background: var(--color-red-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(229,57,53,0.35);
}

.pf-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  font-size: 0.75rem;
  color: var(--color-text-muted);
  margin: 0;
  text-align: center;
}
.pf-note svg { color: var(--color-navy); flex-shrink: 0; }

/* ── Related Products ── */
.related-section { background: #fff; }
.related-cta { text-align: center; margin-top: 2.5rem; }

/* ── Sticky CTA ── */
.sticky-cta {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--color-navy-dark);
  border-top: 3px solid var(--color-red);
  padding: 0.875rem 1.5rem;
  z-index: 900;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  box-shadow: 0 -8px 24px rgba(0,0,0,0.2);
}
.sticky-cta.visible { transform: translateY(0); }

.sticky-cta-inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.sticky-product-name {
  font-size: 0.875rem;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sticky-actions {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  flex-shrink: 0;
}

.sticky-phone {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  padding: 0.5rem 0.875rem;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}
.sticky-phone:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

.sticky-quote {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: #fff;
  background: var(--color-red);
  text-decoration: none;
  padding: 0.6rem 1.25rem;
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}
.sticky-quote:hover { background: var(--color-red-dark); }

/* ── Lightbox ── */
.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.lightbox.open { opacity: 1; pointer-events: all; }

.lightbox-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.92);
  cursor: zoom-out;
}

.lightbox-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: min(90vw, 1000px);
  max-height: 90vh;
  width: 100%;
}

.lightbox-content img {
  max-width: 100%;
  max-height: 90vh;
  object-fit: contain;
  border-radius: var(--radius-md);
  box-shadow: 0 24px 80px rgba(0,0,0,0.5);
  user-select: none;
}

.lb-close {
  position: absolute;
  top: -3rem; right: 0;
  width: 44px; height: 44px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 50%;
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.lb-close:hover { background: rgba(255,255,255,0.2); }

.lb-prev, .lb-next {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  width: 48px; height: 48px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 50%;
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
  z-index: 2;
}
.lb-prev { left: -4rem; }
.lb-next { right: -4rem; }
.lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.2); }
.lb-prev:disabled, .lb-next:disabled { opacity: 0.3; cursor: not-allowed; }

.lb-counter {
  position: absolute;
  bottom: -2.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.8rem;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.08em;
}

/* ── Responsive ── */
@media (max-width: 1100px) {
  .product-layout { grid-template-columns: 55% 1fr; gap: 2.5rem; }
  .artwork-grid { grid-template-columns: repeat(2, 1fr); }
  .why-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 900px) {
  .product-layout { grid-template-columns: 1fr; }
  .product-gallery { position: static; }
  .gallery-main-wrap { aspect-ratio: 4/3; }
  .trust-pillars { gap: 0; }
  .pillar { padding: 0.5rem 1rem; }
  .pillar-sep { height: 20px; }
  .quote-layout { grid-template-columns: 1fr; gap: 3rem; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
  .process-steps { flex-direction: column; align-items: center; gap: 1.5rem; }
  .process-connector { width: 2px; height: 2.5rem; margin: 0; background: linear-gradient(180deg, var(--color-gold) 0%, rgba(201,168,76,0.3) 100%); }
  .aggregate-rating { flex-direction: column; gap: 1.5rem; text-align: center; }
  .sticky-product-name { display: none; }
}

@media (max-width: 640px) {
  .tabs-nav { padding: 0 1rem; }
  .tab-pill { padding: 0.875rem 0.875rem; font-size: 0.8rem; }
  .tab-panel { padding: 1.75rem 1.25rem 2rem; }
  .product-cta-wrap { flex-direction: column; }
  .btn-cta-primary, .btn-cta-secondary { flex: auto; width: 100%; }
  .mf-row { grid-template-columns: 1fr; }
  .pf-row { grid-template-columns: 1fr; }
  .quote-form-card { padding: 1.75rem; }
  .trust-pillars { flex-direction: column; align-items: flex-start; padding: 0.5rem 0; }
  .pillar-sep { display: none; }
  .artwork-grid { grid-template-columns: 1fr; }
  .lb-prev { left: -2rem; }
  .lb-next { right: -2rem; }
}

/* ════════════════════════════════════════════════
   CONFIGURATOR
════════════════════════════════════════════════ */
.configurator-section {
  padding: 5rem 0;
  background: linear-gradient(180deg, var(--color-off-white) 0%, #fff 100%);
  border-top: 1px solid var(--color-border);
}

.cfg-header {
  text-align: center;
  margin-bottom: 3rem;
}
.cfg-header p { max-width: 560px; margin: 0.75rem auto 0; font-size: 1rem; }

/* Two-column layout */
.cfg-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 2.5rem;
  align-items: start;
}

/* ── Steps ── */
.cfg-options { display: flex; flex-direction: column; gap: 2rem; }

.cfg-step {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 1.75rem;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s;
}
.cfg-step:focus-within { box-shadow: var(--shadow-md); border-color: rgba(201,168,76,0.4); }

.cfg-step-label {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  margin-bottom: 1.25rem;
}
.cfg-step-num {
  width: 32px; height: 32px;
  background: var(--color-navy);
  color: var(--color-gold);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9rem;
  flex-shrink: 0;
}
.cfg-step-label h3 {
  font-size: 1rem;
  font-family: var(--font-body);
  font-weight: 700;
  color: var(--color-navy);
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.625rem;
  flex-wrap: wrap;
}
.cfg-multi-hint {
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--color-text-muted);
  background: var(--color-border-light);
  padding: 0.15rem 0.5rem;
  border-radius: 100px;
  letter-spacing: 0;
  font-family: var(--font-body);
}
.cfg-optional {
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--color-text-muted);
  letter-spacing: 0;
  font-family: var(--font-body);
}

/* Card grid */
.cfg-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
.cfg-cards.cfg-multi .cfg-card[aria-pressed="true"] {
  background: var(--color-navy);
  border-color: var(--color-navy);
  color: #fff;
}
.cfg-cards.cfg-multi .cfg-card[aria-pressed="true"] .cfg-card-sub { color: rgba(255,255,255,0.65); }

.cfg-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0.875rem 0.75rem;
  background: var(--color-off-white);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all 0.2s;
  font-family: var(--font-body);
  gap: 0.25rem;
}
.cfg-card:hover {
  border-color: var(--color-gold);
  background: var(--color-gold-pale);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(201,168,76,0.2);
}
.cfg-card[aria-pressed="true"] {
  background: var(--color-gold-pale);
  border-color: var(--color-gold);
  box-shadow: 0 4px 12px rgba(201,168,76,0.25);
}
.cfg-card-title {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--color-navy);
  line-height: 1.3;
}
.cfg-card[aria-pressed="true"] .cfg-card-title { color: var(--color-navy); }
.cfg-card-sub {
  font-size: 0.7rem;
  color: var(--color-text-muted);
  line-height: 1.3;
}
.cfg-card-mat { grid-template-rows: auto auto auto; }
.cfg-mat-icon { font-size: 1.4rem; line-height: 1; margin-bottom: 0.15rem; }

/* Material swatch bar */
.cfg-card-mat[aria-pressed="true"]::after {
  content: '';
  display: block;
  width: 20px; height: 4px;
  border-radius: 2px;
  background: var(--color-gold);
  margin-top: 0.35rem;
}

/* Custom size */
.custom-dims {
  margin-top: 1rem;
  display: none;
}
.custom-dims.visible { display: block; }

.dims-row {
  display: flex;
  align-items: flex-end;
  gap: 0.625rem;
  flex-wrap: wrap;
}
.dim-group {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  flex: 1;
  min-width: 70px;
}
.dim-group label { font-size: 0.75rem; font-weight: 600; color: var(--color-navy); }
.dim-group input {
  padding: 0.6rem 0.75rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-family: var(--font-body);
  color: var(--color-text);
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
}
.dim-group input:focus { border-color: var(--color-navy); }
.dim-sep { color: var(--color-text-muted); font-weight: 700; padding-bottom: 0.5rem; flex-shrink: 0; }
.dim-unit {
  padding: 0.6rem 0.5rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  font-family: var(--font-body);
  color: var(--color-navy);
  outline: none;
  cursor: pointer;
  align-self: flex-end;
  background: #fff;
}

/* Quantity presets */
.qty-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 0.625rem;
  margin-bottom: 1rem;
}
.qty-btn {
  padding: 0.6rem 1rem;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-off-white);
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-navy);
  cursor: pointer;
  transition: all 0.2s;
}
.qty-btn:hover { border-color: var(--color-gold); background: var(--color-gold-pale); }
.qty-btn[aria-pressed="true"] { background: var(--color-navy); border-color: var(--color-navy); color: #fff; }

.custom-qty-wrap { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.custom-qty-label { font-size: 0.8rem; color: var(--color-text-muted); white-space: nowrap; }
.custom-qty-input {
  padding: 0.6rem 0.875rem;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-family: var(--font-body);
  color: var(--color-text);
  outline: none;
  transition: border-color 0.2s;
  width: 140px;
}
.custom-qty-input:focus { border-color: var(--color-navy); }

/* Upload zone */
.cfg-upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 2rem 1.5rem;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-off-white);
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}
.cfg-upload-zone:hover, .cfg-upload-zone.drag-over {
  border-color: var(--color-gold);
  background: var(--color-gold-pale);
}
.cfg-upload-zone input[type="file"] { display: none; }
.cfg-upload-icon { color: var(--color-gold); }
.cfg-upload-text strong { display: block; font-size: 0.9rem; color: var(--color-navy); margin-bottom: 0.2rem; }
.cfg-upload-text span { font-size: 0.75rem; color: var(--color-text-muted); }
.cfg-upload-status { font-size: 0.8rem; color: var(--color-navy); font-weight: 600; min-height: 1rem; }

/* Design help toggle */
.cfg-step-design { }
.cfg-design-toggle {
  display: flex;
  align-items: center;
  gap: 1rem;
  cursor: pointer;
  padding: 1rem;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-off-white);
  transition: all 0.2s;
  user-select: none;
}
.cfg-design-toggle:hover { border-color: var(--color-gold); background: var(--color-gold-pale); }
.cfg-design-toggle input { display: none; }

.toggle-track {
  width: 44px; height: 24px;
  background: var(--color-border);
  border-radius: 100px;
  position: relative;
  flex-shrink: 0;
  transition: background 0.25s;
}
.cfg-design-toggle:has(input:checked) .toggle-track { background: var(--color-navy); }
.cfg-design-toggle:has(input:checked) { border-color: var(--color-navy); }

.toggle-thumb {
  position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  transition: transform 0.25s;
}
.cfg-design-toggle:has(input:checked) .toggle-thumb { transform: translateX(20px); }

.cfg-design-text strong { display: block; font-size: 0.9rem; color: var(--color-navy); margin-bottom: 0.2rem; }
.cfg-design-text span { font-size: 0.78rem; color: var(--color-text-muted); line-height: 1.5; }

/* CTAs */
.cfg-cta-bar {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}
.cfg-cta-primary {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1.05rem 1.75rem;
  background: var(--color-red);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 700;
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all var(--transition);
  text-decoration: none;
  letter-spacing: 0.02em;
}
.cfg-cta-primary:hover {
  background: var(--color-red-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(229,57,53,0.35);
}
.cfg-cta-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1.05rem 1.5rem;
  background: transparent;
  color: var(--color-navy);
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  text-decoration: none;
  transition: all var(--transition);
  flex-shrink: 0;
}
.cfg-cta-secondary:hover { border-color: var(--color-navy); background: var(--color-navy); color: #fff; }

/* ── Summary Panel ── */
.cfg-summary-col { position: relative; }

.cfg-summary {
  position: sticky;
  top: 1.5rem;
  background: #fff;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}

/* Preview */
.preview-wrap {
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  padding: 1.5rem 1.5rem 1rem;
  position: relative;
}
.preview-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.75);
  margin-bottom: 0.875rem;
}
.preview-dot {
  width: 7px; height: 7px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
.preview-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 180px;
}
.preview-box-svg { width: 100%; max-width: 220px; filter: drop-shadow(0 8px 20px rgba(0,0,0,0.4)); }

.preview-finish-badges {
  position: absolute;
  bottom: 0; right: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  justify-content: flex-end;
}

.artwork-file-badge {
  position: absolute;
  top: 0.75rem; left: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-sm);
  padding: 0.35rem 0.6rem;
  color: rgba(255,255,255,0.85);
  font-size: 0.7rem;
  font-weight: 600;
  max-width: 140px;
  overflow: hidden;
}
.artwork-file-badge span {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.finish-badge {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 0.2rem 0.4rem;
  border-radius: 4px;
  background: rgba(201,168,76,0.9);
  color: var(--color-navy-dark);
}

.preview-caption {
  text-align: center;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  margin-top: 0.5rem;
  min-height: 1.1rem;
  font-style: italic;
}

/* Summary list */
.summary-list {
  display: flex;
  flex-direction: column;
  padding: 1rem 1.25rem 0;
}
.summary-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--color-border-light);
  font-size: 0.82rem;
}
.summary-row:last-child { border-bottom: none; }
.sum-label { color: var(--color-text-muted); font-weight: 500; flex-shrink: 0; }
.sum-val {
  color: var(--color-navy);
  font-weight: 600;
  text-align: right;
  word-break: break-word;
}
.sum-val.selected { color: var(--color-navy); }
.sum-val.empty { color: var(--color-text-muted); font-weight: 400; font-style: italic; }

/* Price estimate */
.price-estimate-box {
  margin: 0.75rem 1.25rem;
  padding: 1rem;
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  border-radius: var(--radius-md);
  text-align: center;
}
.price-est-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 0.375rem;
}
.price-est-amount {
  font-family: var(--font-display);
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--color-gold);
  margin-bottom: 0.375rem;
  transition: all 0.3s ease;
  line-height: 1.2;
}
.price-est-note {
  font-size: 0.68rem;
  color: rgba(255,255,255,0.45);
  line-height: 1.4;
}

/* Trust mini */
.cfg-trust-mini {
  padding: 0.875rem 1.25rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.cfg-trust-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--color-text-muted);
}
.cfg-trust-check {
  width: 18px; height: 18px;
  background: var(--color-gold);
  color: var(--color-navy-dark);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem;
  font-weight: 800;
  flex-shrink: 0;
}

/* Responsive */
@media (max-width: 1100px) {
  .cfg-layout { grid-template-columns: 1fr 300px; }
  .cfg-cards { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .cfg-layout { grid-template-columns: 1fr; }
  .cfg-summary-col { order: -1; }
  .cfg-summary { position: static; }
  .preview-stage { min-height: 140px; }
}
@media (max-width: 600px) {
  .cfg-cards { grid-template-columns: repeat(2, 1fr); }
  .cfg-step { padding: 1.25rem; }
  .cfg-cta-bar { flex-direction: column; }
  .cfg-cta-primary, .cfg-cta-secondary { flex: auto; width: 100%; }
}
</style>

<!-- ═══════════════════════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════════════════════════ -->
<script>
  // Read images from the data attribute (avoids define:vars / TypeScript cast issues)
  const galleryWrap = document.getElementById('gallery-main-wrap');
  const images: string[] = galleryWrap ? JSON.parse(galleryWrap.dataset.images || '[]') : [];

  /* ── Gallery ── */
  const mainImg = document.getElementById('main-img') as HTMLImageElement | null;
  const counter = document.getElementById('gallery-counter');
  const thumbs  = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');
  let currentIdx = 0;

  function setImage(idx: number) {
    if (!mainImg || !images[idx]) return;
    currentIdx = idx;
    mainImg.style.opacity = '0';
    setTimeout(() => {
      mainImg!.src = images[idx];
      mainImg!.style.opacity = '1';
    }, 200);
    thumbs.forEach((t, i) => t.classList.toggle('active', i === idx));
    if (counter) counter.textContent = `${idx + 1} / ${images.length}`;
  }

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener('click', () => setImage(i));
  });

  /* ── Lightbox ── */
  const lightbox  = document.getElementById('lightbox');
  const lbImg     = document.getElementById('lb-img') as HTMLImageElement | null;
  const lbCounter = document.getElementById('lb-counter');
  const lbOverlay = document.getElementById('lb-overlay');
  const lbClose   = document.getElementById('lb-close');
  const lbPrev    = document.getElementById('lb-prev') as HTMLButtonElement | null;
  const lbNext    = document.getElementById('lb-next') as HTMLButtonElement | null;
  let lbIdx = 0;

  function openLightbox(idx: number) {
    if (!lightbox || !lbImg) return;
    lbIdx = idx;
    lbImg.src = images[idx];
    if (lbCounter) lbCounter.textContent = `${idx + 1} / ${images.length}`;
    lightbox.classList.add('open');
    lightbox.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    updateLbButtons();
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function lbNavigate(dir: number) {
    lbIdx = (lbIdx + dir + images.length) % images.length;
    if (lbImg) {
      lbImg.style.opacity = '0';
      setTimeout(() => {
        lbImg!.src = images[lbIdx];
        lbImg!.style.opacity = '1';
      }, 150);
    }
    if (lbCounter) lbCounter.textContent = `${lbIdx + 1} / ${images.length}`;
    updateLbButtons();
  }

  function updateLbButtons() {
    if (images.length <= 1) {
      lbPrev?.setAttribute('disabled', '');
      lbNext?.setAttribute('disabled', '');
    } else {
      lbPrev?.removeAttribute('disabled');
      lbNext?.removeAttribute('disabled');
    }
  }

  document.getElementById('open-lightbox')?.addEventListener('click', () => openLightbox(currentIdx));
  galleryWrap?.addEventListener('click', (e: MouseEvent) => {
    if (!(e.target as HTMLElement).closest('#open-lightbox')) openLightbox(currentIdx);
  });
  lbClose?.addEventListener('click', closeLightbox);
  lbOverlay?.addEventListener('click', closeLightbox);
  lbPrev?.addEventListener('click', () => lbNavigate(-1));
  lbNext?.addEventListener('click', () => lbNavigate(1));

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (!lightbox?.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft')  lbNavigate(-1);
    if (e.key === 'ArrowRight') lbNavigate(1);
  });

  /* ── Tabs ── */
  const tabPills  = document.querySelectorAll<HTMLButtonElement>('.tab-pill');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabPills.forEach((pill, i) => {
    pill.addEventListener('click', () => {
      tabPills.forEach(p => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
      tabPanels.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      pill.setAttribute('aria-selected', 'true');
      tabPanels[i]?.classList.add('active');
    });
  });

  /* ── FAQ Accordion ── */
  document.querySelectorAll<HTMLButtonElement>('.faq-q-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item-premium');
      const isOpen = item?.classList.contains('open');
      document.querySelectorAll('.faq-item-premium.open').forEach(o => {
        o.classList.remove('open');
        o.querySelector('.faq-q-btn')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen && item) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  /* ── Sticky CTA ── */
  const stickyCta = document.getElementById('sticky-cta');
  const heroEl    = document.querySelector('.product-hero');

  if (stickyCta && heroEl) {
    const io = new IntersectionObserver(([entry]) => {
      stickyCta.classList.toggle('visible', !entry.isIntersecting);
      stickyCta.setAttribute('aria-hidden', String(entry.isIntersecting));
    }, { threshold: 0.1 });
    io.observe(heroEl);
  }

  /* ══════════════════════════════════════════
     CONFIGURATOR
  ══════════════════════════════════════════ */
  (function() {

    /* ── State ── */
    interface CfgState {
      size: string; customL: string; customW: string; customH: string; customUnit: string;
      material: string; materialColor: string;
      printing: Set<string>; finish: Set<string>;
      qty: number; customQty: string;
      addon: Set<string>;
      artworkNames: string[];
      designHelp: boolean;
    }

    const state: CfgState = {
      size: '', customL: '', customW: '', customH: '', customUnit: 'cm',
      material: '', materialColor: '#1a3a5c',
      printing: new Set(), finish: new Set(),
      qty: 0, customQty: '',
      addon: new Set(),
      artworkNames: [],
      designHelp: false,
    };

    /* ── Price tables ── */
    const matBase: Record<string,number> = {
      cardboard: 1.20, kraft: 0.95, corrugated: 1.45, rigid: 2.80, eco: 1.35
    };
    const qtyScale: [number,number][] = [
      [10000,0.82],[5000,1.0],[2500,1.28],[1000,1.65],[500,2.10],[250,2.75],[100,3.40],[1,4.20]
    ];
    const printAdd: Record<string,number> = {
      none:-0.18, cmyk:0, pms:0.28, inside:0.18, outside:0.10, both:0.32
    };
    const finishAdd: Record<string,number> = {
      gloss:0.14, matte:0.14, spotUV:0.24, goldFoil:0.34, silvFoil:0.28, emboss:0.28, deboss:0.24, softTch:0.20
    };
    const addonAdd: Record<string,number> = {
      insert:0.22, window:0.18, ribbon:0.26, magnetic:0.44, handles:0.20, sleeves:0.28
    };

    /* ── Box SVG color palette by material ── */
    const matColors: Record<string,[string,string,string]> = {
      cardboard:  ['#d4c5a9','#6b7f94','#4a5a6a'],
      kraft:      ['#c9a87a','#7a5c3a','#5a3c20'],
      corrugated: ['#c4a882','#8b6b4a','#6b4b2a'],
      rigid:      ['#8090a0','#2a3a4a','#1a2a3a'],
      eco:        ['#9dba78','#4a7a3a','#2a5a1a'],
    };

    /* ── DOM refs ── */
    const boxTop   = document.getElementById('box-top') as SVGPolygonElement | null;
    const boxLeft  = document.getElementById('box-left') as SVGPolygonElement | null;
    const boxRight = document.getElementById('box-right') as SVGPolygonElement | null;
    const boxFoil  = document.getElementById('box-foil') as SVGPolygonElement | null;
    const finishBadges  = document.getElementById('preview-finish-badges');
    const previewCaption = document.getElementById('preview-caption');
    const priceAmount    = document.getElementById('price-est-amount');
    const customDims     = document.getElementById('custom-dims');

    /* ── Utility ── */
    function calcPrice(): { low: number; high: number } | null {
      if (!state.material || !state.qty) return null;
      const base = matBase[state.material] ?? 1.2;
      const scale = qtyScale.find(([q]) => state.qty >= q)?.[1] ?? 4.2;
      let add = 0;
      state.printing.forEach(p => { add += printAdd[p] ?? 0; });
      state.finish.forEach(f  => { add += finishAdd[f] ?? 0; });
      state.addon.forEach(a   => { add += addonAdd[a] ?? 0; });
      const unit = (base + add) * scale;
      const total = unit * state.qty;
      return { low: Math.round(total * 0.88), high: Math.round(total * 1.14) };
    }

    function getSizeLabel(): string {
      const sizeMap: Record<string,string> = {
        xs:'Extra Small (5×5×3cm)', sm:'Small (10×8×4cm)',
        md:'Medium (15×12×6cm)',    lg:'Large (20×15×10cm)',
        xl:'Extra Large (30×25×15cm)',
      };
      if (state.size === 'cus' && (state.customL || state.customW || state.customH)) {
        return `Custom: ${state.customL||'?'}×${state.customW||'?'}×${state.customH||'?'} ${state.customUnit}`;
      }
      return sizeMap[state.size] || '';
    }

    function getSetLabel(s: Set<string>, map: Record<string,string>): string {
      if (s.size === 0) return '';
      return [...s].map(k => map[k] || k).join(', ');
    }

    const printLabels: Record<string,string> = {
      none:'No Printing', cmyk:'Full Colour CMYK', pms:'PMS Spot',
      inside:'Inside Print', outside:'Outside Print', both:'Both Sides'
    };
    const finishLabels: Record<string,string> = {
      gloss:'Gloss Lam', matte:'Matte Lam', spotUV:'Spot UV',
      goldFoil:'Gold Foil', silvFoil:'Silver Foil',
      emboss:'Embossing', deboss:'Debossing', softTch:'Soft-Touch'
    };
    const addonLabels: Record<string,string> = {
      insert:'Inserts', window:'Window Cut', ribbon:'Ribbon',
      magnetic:'Magnetic Closure', handles:'Handles', sleeves:'Sleeves'
    };
    const matLabels: Record<string,string> = {
      cardboard:'Cardboard', kraft:'Kraft', corrugated:'Corrugated', rigid:'Rigid Board', eco:'Eco-Friendly'
    };
    const qtyLabels: Record<number,string> = {
      100:'100',250:'250',500:'500',1000:'1,000',2500:'2,500',5000:'5,000',10000:'10,000+'
    };

    /* ── Update summary panel ── */
    function updateSummary() {
      const pairs: [string, string][] = [
        ['size',     getSizeLabel()],
        ['material', matLabels[state.material] || ''],
        ['printing', getSetLabel(state.printing, printLabels)],
        ['finish',   getSetLabel(state.finish, finishLabels)],
        ['qty',      state.qty ? (qtyLabels[state.qty] || state.qty.toLocaleString()) : (state.customQty ? state.customQty + ' units' : '')],
        ['addon',    getSetLabel(state.addon, addonLabels)],
        ['design',   state.designHelp ? 'Yes — free design requested' : ''],
      ];

      pairs.forEach(([key, val]) => {
        const el = document.getElementById(`sum-val-${key}`);
        if (!el) return;
        if (val) {
          el.textContent = val;
          el.className = 'sum-val selected';
        } else {
          el.textContent = key === 'finish' || key === 'addon' ? 'None' : key === 'design' ? 'Not requested' : 'Not selected';
          el.className = 'sum-val empty';
        }
      });

      /* Price */
      const price = calcPrice();
      if (priceAmount) {
        if (price) {
          priceAmount.textContent = `AUD $${price.low.toLocaleString()} – $${price.high.toLocaleString()}`;
        } else {
          priceAmount.textContent = 'Select material & quantity';
        }
      }

      /* Box SVG */
      const colors = matColors[state.material] ?? ['#c9a84c','#1a3a5c','#0d2035'];
      if (boxTop)   boxTop.setAttribute('fill', colors[0]);
      if (boxLeft)  boxLeft.setAttribute('fill', colors[1]);
      if (boxRight) boxRight.setAttribute('fill', colors[2]);

      /* Foil shimmer */
      if (boxFoil) {
        boxFoil.setAttribute('opacity', (state.finish.has('goldFoil') || state.finish.has('silvFoil')) ? '0.6' : '0');
      }

      /* Finish badges */
      if (finishBadges) {
        finishBadges.innerHTML = '';
        state.finish.forEach(f => {
          const b = document.createElement('span');
          b.className = 'finish-badge';
          b.textContent = finishLabels[f] || f;
          finishBadges.appendChild(b);
        });
      }

      /* Caption */
      if (previewCaption) {
        const parts = [matLabels[state.material], getSizeLabel()].filter(Boolean);
        previewCaption.textContent = parts.length ? parts.join(' · ') : 'Select options to preview';
      }
    }

    /* ── Single-select handler ── */
    function bindSingle(groupId: string, stateKey: keyof CfgState, onChange?: (val: string) => void) {
      document.querySelectorAll<HTMLButtonElement>(`[data-group="${groupId}"]`).forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll(`[data-group="${groupId}"]`).forEach(b => b.setAttribute('aria-pressed','false'));
          btn.setAttribute('aria-pressed','true');
          (state as any)[stateKey] = btn.dataset.val || '';
          onChange && onChange(btn.dataset.val || '');
          updateSummary();
        });
      });
    }

    /* ── Multi-select handler ── */
    function bindMulti(groupId: string, stateSet: Set<string>) {
      document.querySelectorAll<HTMLButtonElement>(`[data-group="${groupId}"]`).forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.dataset.val || '';
          if (stateSet.has(val)) { stateSet.delete(val); btn.setAttribute('aria-pressed','false'); }
          else                   { stateSet.add(val);    btn.setAttribute('aria-pressed','true');  }
          updateSummary();
        });
      });
    }

    /* ── Bind all groups ── */
    bindSingle('size', 'size', val => {
      if (customDims) customDims.classList.toggle('visible', val === 'cus');
    });

    bindSingle('material', 'material');

    bindMulti('printing', state.printing);
    bindMulti('finish',   state.finish);
    bindMulti('addon',    state.addon);

    /* Quantity single-select */
    document.querySelectorAll<HTMLButtonElement>('[data-group="qty"]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-group="qty"]').forEach(b => b.setAttribute('aria-pressed','false'));
        btn.setAttribute('aria-pressed','true');
        state.qty = Number(btn.dataset.val) || 0;
        state.customQty = '';
        const cqi = document.getElementById('custom-qty') as HTMLInputElement | null;
        if (cqi) cqi.value = '';
        updateSummary();
      });
    });

    /* Custom quantity */
    const customQtyInput = document.getElementById('custom-qty') as HTMLInputElement | null;
    customQtyInput?.addEventListener('input', () => {
      state.customQty = customQtyInput.value;
      state.qty = Number(customQtyInput.value) || 0;
      document.querySelectorAll('[data-group="qty"]').forEach(b => b.setAttribute('aria-pressed','false'));
      updateSummary();
    });

    /* Custom dimensions */
    ['dim-l','dim-w','dim-h'].forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      el?.addEventListener('input', () => {
        state.customL = (document.getElementById('dim-l') as HTMLInputElement)?.value || '';
        state.customW = (document.getElementById('dim-w') as HTMLInputElement)?.value || '';
        state.customH = (document.getElementById('dim-h') as HTMLInputElement)?.value || '';
        updateSummary();
      });
    });
    const dimUnit = document.getElementById('dim-unit') as HTMLSelectElement | null;
    dimUnit?.addEventListener('change', () => { state.customUnit = dimUnit.value; updateSummary(); });

    /* Design help toggle */
    const designCheck = document.getElementById('cfg-design-help') as HTMLInputElement | null;
    designCheck?.addEventListener('change', () => { state.designHelp = designCheck.checked; updateSummary(); });

    /* Artwork upload */
    const artworkInput2   = document.getElementById('cfg-artwork') as HTMLInputElement | null;
    const uploadStatus    = document.getElementById('cfg-upload-status');
    const uploadZone      = document.getElementById('cfg-upload-zone');
    const artworkFront    = document.getElementById('artwork-front') as SVGImageElement | null;
    const artworkRight    = document.getElementById('artwork-right') as SVGImageElement | null;
    const logoPlaceholder = document.getElementById('logo-placeholder');
    const fileBadge       = document.getElementById('artwork-file-badge');
    const fileBadgeName   = document.getElementById('artwork-file-name');

    const IMAGE_TYPES = ['image/jpeg','image/png','image/webp','image/gif','image/svg+xml'];

    function applyArtwork(file: File) {
      state.artworkNames = [file.name];
      if (uploadStatus) uploadStatus.textContent = `✓ ${file.name}`;

      if (IMAGE_TYPES.includes(file.type)) {
        /* Show image on box faces */
        const reader = new FileReader();
        reader.onload = (e) => {
          const src = e.target?.result as string;
          if (artworkFront) { artworkFront.setAttribute('href', src); artworkFront.style.opacity = '1'; }
          if (artworkRight) { artworkRight.setAttribute('href', src); artworkRight.style.opacity = '0.75'; }
          if (logoPlaceholder) logoPlaceholder.setAttribute('opacity', '0');
          if (fileBadge) fileBadge.style.display = 'none';
        };
        reader.readAsDataURL(file);
      } else {
        /* Non-image: show file badge, clear image faces */
        if (artworkFront) artworkFront.style.opacity = '0';
        if (artworkRight) artworkRight.style.opacity = '0';
        if (logoPlaceholder) logoPlaceholder.setAttribute('opacity', '0.35');
        if (fileBadge) { fileBadge.style.display = 'flex'; }
        if (fileBadgeName) fileBadgeName.textContent = file.name;
        if (uploadStatus) uploadStatus.textContent = `✓ ${file.name} (ready for upload)`;
      }
    }

    function clearArtwork() {
      state.artworkNames = [];
      if (artworkFront) { artworkFront.setAttribute('href',''); artworkFront.style.opacity = '0'; }
      if (artworkRight) { artworkRight.setAttribute('href',''); artworkRight.style.opacity = '0'; }
      if (logoPlaceholder) logoPlaceholder.setAttribute('opacity', '0.35');
      if (fileBadge) fileBadge.style.display = 'none';
      if (uploadStatus) uploadStatus.textContent = '';
    }

    artworkInput2?.addEventListener('change', () => {
      const files = artworkInput2.files;
      if (files && files.length > 0) applyArtwork(files[0]);
      else clearArtwork();
    });

    /* Drag and drop */
    uploadZone?.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
    uploadZone?.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
    uploadZone?.addEventListener('drop', e => {
      e.preventDefault();
      uploadZone.classList.remove('drag-over');
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) applyArtwork(files[0]);
    });

    /* ── "Add to Quote" → pre-fill form ── */
    document.getElementById('cfg-add-quote')?.addEventListener('click', () => {
      const price = calcPrice();
      const lines = [
        `Product: ${document.querySelector('.product-title')?.textContent || ''}`,
        getSizeLabel() ? `Size: ${getSizeLabel()}` : '',
        state.material ? `Material: ${matLabels[state.material]}` : '',
        state.printing.size ? `Printing: ${getSetLabel(state.printing, printLabels)}` : '',
        state.finish.size   ? `Finishes: ${getSetLabel(state.finish, finishLabels)}` : '',
        state.qty           ? `Quantity: ${state.qty.toLocaleString()} units` : '',
        state.addon.size    ? `Add-Ons: ${getSetLabel(state.addon, addonLabels)}` : '',
        state.designHelp    ? 'Design Support: Yes (free)' : '',
        state.artworkNames.length ? `Artwork files: ${state.artworkNames.join(', ')}` : '',
        price ? `Estimated budget: AUD $${price.low.toLocaleString()}–$${price.high.toLocaleString()}` : '',
      ].filter(Boolean).join('\n');

      /* Populate mini form textarea */
      const msgArea = document.querySelector('.mini-form textarea[name="message"]') as HTMLTextAreaElement | null;
      if (msgArea) msgArea.value = lines;

      /* Smooth scroll to mini form */
      const mfWrap = document.querySelector('.mini-form-wrap');
      if (mfWrap) mfWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });

      /* Visual feedback */
      const btn = document.getElementById('cfg-add-quote');
      if (btn) {
        btn.textContent = '✓ Added to Quote Form — Scroll Down';
        btn.style.background = '#16a34a';
        setTimeout(() => {
          btn.innerHTML = `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg> Add to Quote Request`;
          btn.style.background = '';
        }, 3000);
      }
    });

    /* Initial render */
    updateSummary();

  })();

  /* ── Mini form file name ── */
  const artworkInput = document.getElementById('mf-artwork') as HTMLInputElement | null;
  artworkInput?.addEventListener('change', () => {
    const label = document.getElementById('mf-file-text');
    if (label) {
      label.textContent = artworkInput.files?.length
        ? artworkInput.files[0].name
        : 'Upload Artwork (optional)';
    }
  });

  /* ── Scroll Reveal ── */
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if ('IntersectionObserver' in window) {
    const revIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); revIO.unobserve(e.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => revIO.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('visible'));
  }
</script>
