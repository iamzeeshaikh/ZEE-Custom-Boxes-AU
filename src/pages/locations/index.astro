---
import Layout from '../../layouts/Layout.astro';
import { SITE, CTA } from '../../config/site';
import locations from '../../data/locations';

const states  = locations.filter(l => l.type === 'state');
const cities  = locations.filter(l => l.type === 'city');
const national = locations.find(l => l.type === 'national')!;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": `${SITE.url}/locations` },
  ]
};
---

<Layout
  title="Custom Packaging Locations Across Australia | ZEE Custom Boxes AU"
  description="ZEE Custom Boxes AU delivers premium custom packaging to businesses across Australia. Browse state and city packaging pages for your local delivery and service information."
  canonical={`${SITE.url}/locations`}
  schema={breadcrumbSchema}
>

<div class="breadcrumb-bar">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">›</span>
      <span aria-current="page">Locations</span>
    </nav>
  </div>
</div>

<section class="loc-index-hero">
  <div class="container">
    <div class="section-label">Australia-Wide Custom Packaging</div>
    <h1>Custom Packaging Delivered Across Australia</h1>
    <div class="gold-divider"></div>
    <p>ZEE Custom Boxes AU delivers premium custom packaging to businesses in every state and city across Australia. Browse your location below for local delivery information, turnaround times, and industry-specific packaging solutions.</p>
  </div>
</section>

<section class="section">
  <div class="container">

    <!-- National -->
    <div class="loc-index-block">
      <h2 class="loc-index-heading">Australia-Wide</h2>
      <div class="loc-index-grid loc-index-grid--wide">
        <a href={`/${national.slug}`} class="loc-index-card loc-index-card--featured">
          <div class="loc-index-card-badge">National</div>
          <div class="loc-index-card-name">Custom Packaging Australia</div>
          <div class="loc-index-card-sub">Nationwide delivery — all states and territories</div>
          <div class="loc-index-card-arrow">→</div>
        </a>
      </div>
    </div>

    <!-- States -->
    <div class="loc-index-block">
      <h2 class="loc-index-heading">Packaging by State</h2>
      <div class="loc-index-grid">
        {states.map(s => (
          <a href={`/${s.slug}`} class="loc-index-card">
            <div class="loc-index-card-name">{s.name}</div>
            <div class="loc-index-card-sub">Custom packaging across {s.state}</div>
            <div class="loc-index-card-arrow">→</div>
          </a>
        ))}
      </div>
    </div>

    <!-- Cities -->
    <div class="loc-index-block">
      <h2 class="loc-index-heading">Packaging by City</h2>
      <div class="loc-index-grid loc-index-grid--cities">
        {cities.map(c => (
          <a href={`/${c.slug}`} class="loc-index-card loc-index-card--city">
            <div class="loc-index-card-name">{c.name}</div>
            <div class="loc-index-card-sub">{c.state}</div>
            <div class="loc-index-card-arrow">→</div>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- CTA -->
<section class="loc-index-cta">
  <div class="container">
    <h2>Ready to Order Custom Packaging?</h2>
    <p>No matter where you are in Australia — we deliver. Free design, no minimums, 7–14 day production.</p>
    <div class="loc-index-cta-btns">
      <a href={CTA.quoteUrl} class="btn btn-primary btn-lg">Get a Free Quote →</a>
      <a href={`tel:${SITE.phone}`} class="btn btn-outline-light btn-lg">📞 {SITE.phone}</a>
    </div>
  </div>
</section>

</Layout>

<style>
.breadcrumb-bar { background: var(--color-off-white); border-bottom: 1px solid var(--color-border); padding: 0.875rem 0; }

.loc-index-hero {
  background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
  padding: 4rem 0 3rem;
  text-align: center;
}
.loc-index-hero h1 { color: #fff; font-size: clamp(1.8rem, 3.5vw, 2.8rem); margin-bottom: 0.5rem; }
.loc-index-hero p { color: rgba(255,255,255,0.75); max-width: 640px; margin: 1rem auto 0; }

.loc-index-block { margin-bottom: 3rem; }
.loc-index-heading {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-navy);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border-bottom: 2px solid var(--color-gold);
  padding-bottom: 0.5rem;
  margin-bottom: 1.25rem;
}

.loc-index-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
.loc-index-grid--wide { grid-template-columns: 1fr; max-width: 480px; }
.loc-index-grid--cities { grid-template-columns: repeat(5, 1fr); }

.loc-index-card {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 1.25rem;
  text-decoration: none;
  color: var(--color-navy);
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  position: relative;
}
.loc-index-card:hover { border-color: var(--color-gold); box-shadow: var(--shadow-md); transform: translateY(-2px); }
.loc-index-card--featured { border-color: var(--color-gold); background: linear-gradient(135deg, #fff, rgba(201,168,76,0.05)); }
.loc-index-card--city { padding: 1rem; }
.loc-index-card-badge {
  display: inline-block;
  background: var(--color-gold);
  color: var(--color-navy-dark);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  margin-bottom: 0.4rem;
  width: fit-content;
}
.loc-index-card-name { font-weight: 700; font-size: 0.95rem; }
.loc-index-card--city .loc-index-card-name { font-size: 0.875rem; }
.loc-index-card-sub { font-size: 0.75rem; color: var(--color-text-muted); }
.loc-index-card-arrow { color: var(--color-gold); font-weight: 700; margin-top: auto; padding-top: 0.5rem; }

.loc-index-cta {
  background: linear-gradient(135deg, var(--color-navy), var(--color-navy-dark));
  padding: 4rem 0;
  text-align: center;
}
.loc-index-cta h2 { color: #fff; font-size: clamp(1.5rem, 2.5vw, 2rem); margin-bottom: 0.75rem; }
.loc-index-cta p { color: rgba(255,255,255,0.7); margin-bottom: 2rem; }
.loc-index-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.btn-outline-light {
  background: transparent; border: 2px solid rgba(255,255,255,0.4); color: #fff;
  padding: 0.75rem 1.75rem; border-radius: var(--radius-sm); font-weight: 600;
  text-decoration: none; transition: border-color 0.2s, background 0.2s;
  display: inline-flex; align-items: center; gap: 0.5rem;
}
.btn-outline-light:hover { border-color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.08); }

@media (max-width: 1024px) {
  .loc-index-grid { grid-template-columns: repeat(2, 1fr); }
  .loc-index-grid--cities { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 640px) {
  .loc-index-grid { grid-template-columns: 1fr; }
  .loc-index-grid--cities { grid-template-columns: repeat(2, 1fr); }
}
</style>
