---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { SITE } from '../config/site';
import products from '../data/products.json';
import categories from '../data/categories.json';

const featuredProducts = products.filter(p => p.images.length > 0).slice(0, 8);

const productMap: Record<string, typeof products[0]> = {};
products.forEach(p => { productMap[p.slug] = p; });

const topCategories = categories.slice(0, 12).map(cat => ({
  ...cat,
  thumb: productMap[cat.products[0]]?.images?.[0] || '/images/placeholder.webp',
}));

const heroImages = products.filter(p => p.images.length > 0).slice(0, 3).map(p => p.images[0]);

const trustItems = [
  'Free Design Service', 'No Minimum Order', '7–14 Day Turnaround',
  'Australia-Wide Delivery', 'Premium Materials', '24hr Quote Response',
  'Wholesale Pricing', '5-Star Quality', 'Eco-Friendly Options', 'Custom Sizes & Shapes',
];

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": SITE.phone,
  "email": SITE.email,
  "address": { "@type": "PostalAddress", "addressCountry": "AU" },
  "priceRange": "$$"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the minimum order quantity?", "acceptedAnswer": { "@type": "Answer", "text": "We have no minimum order quantity at ZEE Custom Boxes AU. You can order as few or as many units as your business needs, making us perfect for startups and established brands alike." } },
    { "@type": "Question", "name": "Is the design service really free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Our professional design service is completely free. Our expert designers will create your custom artwork, and you'll receive a 3D digital mockup for approval before we go to print." } },
    { "@type": "Question", "name": "How long does production take?", "acceptedAnswer": { "@type": "Answer", "text": "Standard production typically takes 7–14 business days after artwork approval. We also offer express production options for urgent orders." } },
    { "@type": "Question", "name": "Do you ship across Australia?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we deliver to all states and territories across Australia, including NSW, VIC, QLD, WA, SA, TAS, ACT, and NT." } },
    { "@type": "Question", "name": "What materials do you use?", "acceptedAnswer": { "@type": "Answer", "text": "We offer premium cardboard, kraft paper, rigid board, and corrugated cardboard. Finishing options include gloss lamination, matte lamination, spot UV, foil stamping, soft-touch coating, and embossing or debossing." } },
    { "@type": "Question", "name": "Can I see a sample before ordering?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We provide digital 3D mockups before production. Physical printed samples can also be arranged — contact our team for availability and pricing." } },
    { "@type": "Question", "name": "Do you offer eco-friendly packaging?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! We offer sustainable packaging options including recycled cardboard, FSC-certified kraft paper, and soy-based inks." } },
    { "@type": "Question", "name": "What types of custom boxes can you produce?", "acceptedAnswer": { "@type": "Answer", "text": "We produce over 373 types of custom packaging including cosmetic boxes, food boxes, gift boxes, retail boxes, mailer boxes, tuck-end boxes, rigid boxes, sleeve boxes, display boxes, and more." } },
    { "@type": "Question", "name": "How do I get a quote?", "acceptedAnswer": { "@type": "Answer", "text": "Fill out our free quote form with your packaging type, quantity, dimensions, and design requirements. Our team will respond within 24 business hours with a detailed quote at no obligation." } },
    { "@type": "Question", "name": "Can you print my logo and branding on the boxes?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. All packaging is fully custom-printed with your logo, brand colours, and artwork. Our designers handle the artwork at no extra charge." } },
    { "@type": "Question", "name": "Do you offer wholesale pricing?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we offer competitive wholesale pricing with volume discounts on every order. The larger your order, the better the per-unit price." } },
    { "@type": "Question", "name": "What if I'm not happy with my order?", "acceptedAnswer": { "@type": "Answer", "text": "If there is a quality issue or your order does not match the approved artwork, we will reprint or refund — no hassle. Contact our team within 7 days of receiving your order." } },
  ]
};
---

<Layout
  title="Custom Packaging Boxes Australia | ZEE Custom Boxes AU"
  description="Australia's premium custom packaging supplier. Order custom boxes for cosmetics, food, retail & gifts. Free design, fast turnaround, wholesale prices. Get your free quote today."
  schema={[homeSchema, faqSchema]}
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-dots"></div>
      <div class="hero-glow-1"></div>
      <div class="hero-glow-2"></div>
    </div>
    <div class="container">
      <div class="hero-inner">

        <div class="hero-content">
          <div class="hero-eyebrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Australia's Premium Custom Packaging Partner
          </div>
          <h1 class="hero-title">
            Premium Custom Packaging
            <span class="hero-accent">That Elevates Your Brand</span>
          </h1>
          <p class="hero-desc">
            From luxury cosmetic boxes to custom food packaging — ZEE Custom Boxes AU delivers bespoke packaging with <strong>free professional design</strong>, fast turnaround, and competitive wholesale pricing across Australia.
          </p>
          <div class="hero-actions">
            <a href="/request-quote" class="btn btn-primary btn-lg">Get Your Free Quote →</a>
            <a href="/products" class="btn btn-ghost-white btn-lg">Browse All Products</a>
          </div>
          <div class="hero-trust-row">
            <div class="hero-rating">
              <div class="hero-stars">★★★★★</div>
              <div class="hero-rating-copy"><strong>4.9/5</strong> · 200+ reviews</div>
            </div>
            <span class="hero-trust-sep"></span>
            <div class="hero-pillars">
              <span class="hero-pillar">373+ Products</span>
              <span class="hero-pillar">500+ Clients</span>
              <span class="hero-pillar">Free Design</span>
            </div>
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="hero-mosaic">
            <div class="hm-card hm-main">
              <img src={heroImages[0] || '/images/placeholder.webp'} alt="Custom Packaging Australia" loading="eager" />
              <div class="hm-tag">Cosmetic Boxes</div>
            </div>
            <div class="hm-col-right">
              <div class="hm-card hm-sm">
                <img src={heroImages[1] || '/images/placeholder.webp'} alt="Gift Packaging" loading="eager" />
                <div class="hm-tag">Gift Boxes</div>
              </div>
              <div class="hm-card hm-sm">
                <img src={heroImages[2] || '/images/placeholder.webp'} alt="Food Packaging" loading="eager" />
              </div>
            </div>
            <div class="hm-float hm-float-design">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Free Design
            </div>
            <div class="hm-float hm-float-ship">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              AU-Wide Shipping
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== MARQUEE BAR ===================== -->
  <div class="marquee-bar" aria-hidden="true">
    <div class="marquee-track">
      <div class="marquee-content">
        {[...trustItems, ...trustItems].map(item => (
          <div class="marquee-item">
            <span class="marquee-dot"></span>
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ===================== CATEGORIES ===================== -->
  <section class="section section-lg">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">Our Collections</div>
        <h2>Premium Packaging Categories</h2>
        <div class="gold-divider"></div>
        <p>Explore our extensive range of custom packaging solutions crafted for every industry and occasion.</p>
      </div>

      <div class="cat-grid-prem">
        {topCategories.map((cat, i) => (
          <a href={`/category/${cat.slug}`} class="cat-card-prem reveal" style={`animation-delay: ${i * 0.04}s`}>
            <div class="cat-img-wrap-prem">
              <img src={cat.thumb} alt={`Custom ${cat.name} Australia`} loading={i < 4 ? 'eager' : 'lazy'} />
              <div class="cat-grad"></div>
              <div class="cat-overlay-content">
                <h3>{cat.name}</h3>
                <span class="cat-shop-btn">Shop Now →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center" style="margin-top: 3rem;">
        <a href="/products" class="btn btn-navy btn-lg">View All 373 Products →</a>
      </div>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-inner">
        <div class="stat-block reveal">
          <div class="stat-num" data-target="10" data-suffix="+">10+</div>
          <div class="stat-name">Years in Business</div>
          <div class="stat-note">Serving Australia since 2014</div>
        </div>
        <div class="stat-block reveal" style="animation-delay:0.1s">
          <div class="stat-num" data-target="500" data-suffix="+">500+</div>
          <div class="stat-name">Happy Clients</div>
          <div class="stat-note">Across all industries nationwide</div>
        </div>
        <div class="stat-block reveal" style="animation-delay:0.2s">
          <div class="stat-num">4.9★</div>
          <div class="stat-name">Average Rating</div>
          <div class="stat-note">Google &amp; verified reviews</div>
        </div>
        <div class="stat-block reveal" style="animation-delay:0.3s">
          <div class="stat-num" data-target="373" data-suffix="+">373+</div>
          <div class="stat-name">Product Types</div>
          <div class="stat-note">28 packaging categories</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FEATURED PRODUCTS ===================== -->
  <section class="section bg-light">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">Popular Products</div>
        <h2>Featured Packaging Solutions</h2>
        <div class="gold-divider"></div>
        <p>Our most popular custom packaging products — trusted by hundreds of Australian businesses.</p>
      </div>
      <div class="grid-4">
        {featuredProducts.map((product, i) => (
          <div class="reveal" style={`animation-delay: ${i * 0.06}s`}>
            <ProductCard product={product} eager={i < 4} />
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/products" class="btn btn-primary btn-lg">Browse All 373 Products →</a>
      </div>
    </div>
  </section>

  <!-- ===================== WHY ZEE ===================== -->
  <section class="section why-new-section">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">Why ZEE Custom Boxes AU</div>
        <h2>Everything You Need for Perfect Packaging</h2>
        <div class="gold-divider"></div>
        <p>We go beyond printing boxes — we craft premium packaging experiences that reflect your brand's quality and values.</p>
      </div>
      <div class="why-cards-grid">
        {([
          {
            title: 'Free Professional Design',
            desc: 'Expert designers craft your bespoke artwork at zero cost. Review and approve your 3D mockup before we print a single sheet.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
          },
          {
            title: 'Premium Materials',
            desc: 'Cardboard, kraft, rigid, corrugated — with luxury finishing options including gloss, matte, foil stamping, spot UV, and embossing.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>',
          },
          {
            title: 'No Minimum Order',
            desc: 'Order as few or as many as you need. Ideal for product launches, seasonal campaigns, and large wholesale runs alike.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z"/></svg>',
          },
          {
            title: 'Fast Turnaround',
            desc: 'Standard production in 7–14 business days after artwork approval. Express options available for urgent orders.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
          },
          {
            title: 'Australia-Wide Delivery',
            desc: 'We ship to Sydney, Melbourne, Brisbane, Perth, Adelaide, Darwin, Hobart — every state and territory, fast.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>',
          },
          {
            title: 'Wholesale Pricing',
            desc: 'Volume discounts on every order. Transparent quotes with no hidden fees — the more you order, the better the price.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>',
          },
        ] as const).map((feat, i) => (
          <div class="why-card reveal" style={`animation-delay: ${i * 0.07}s`}>
            <div class="why-card-icon" set:html={feat.icon} />
            <h3>{feat.title}</h3>
            <p>{feat.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/about" class="btn btn-outline">Learn More About Us →</a>
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="section bg-light">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">How It Works</div>
        <h2>Simple 4-Step Process</h2>
        <div class="gold-divider"></div>
        <p>From first contact to your door — we make custom packaging effortless.</p>
      </div>
      <div class="process-wrap">
        {([
          {
            num: '01',
            title: 'Request a Quote',
            desc: 'Fill out our simple form with your packaging requirements — size, quantity, material, and design preferences.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
          },
          {
            num: '02',
            title: 'Free Design Proof',
            desc: 'Our designers create your custom artwork for free. Review and approve your 3D digital mockup before production begins.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>',
          },
          {
            num: '03',
            title: 'Production',
            desc: 'Premium materials, strict quality control at every stage. Your order is carefully crafted and tracked throughout.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>',
          },
          {
            num: '04',
            title: 'Fast Delivery',
            desc: 'Your custom packaging arrives straight to your door anywhere in Australia — quickly, safely, and on time.',
            icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
          },
        ] as const).map((step, i) => (
          <div class="process-step reveal" style={`animation-delay: ${i * 0.1}s`}>
            <div class="process-step-circle">
              <span>{step.num}</span>
            </div>
            {i < 3 && <div class="process-connector" aria-hidden="true"></div>}
            <div class="process-icon" set:html={step.icon} />
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3.5rem;">
        <a href="/request-quote" class="btn btn-primary btn-lg">Start Your Order Today →</a>
      </div>
    </div>
  </section>

  <!-- ===================== INDUSTRIES ===================== -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">Industries We Serve</div>
        <h2>Custom Packaging for Every Industry</h2>
        <div class="gold-divider"></div>
        <p>We partner with businesses across every sector in Australia to create packaging that wins customers.</p>
      </div>
      <div class="industries-grid">
        {[
          { name: 'Cosmetics & Beauty', slug: 'custom-cosmetic-boxes-packaging', emoji: '💄' },
          { name: 'Food & Bakery', slug: 'custom-food-packaging-boxes', emoji: '🍰' },
          { name: 'Retail & E-commerce', slug: 'custom-retail-boxes-packaging', emoji: '🛍️' },
          { name: 'Gifts & Luxury', slug: 'custom-gift-packaging-boxes', emoji: '🎁' },
          { name: 'CBD & Wellness', slug: 'custom-cbd-boxes-packaging', emoji: '🌿' },
          { name: 'Pharmaceuticals', slug: 'pharmaceutical-packaging', emoji: '💊' },
          { name: 'Candles & Home', slug: 'custom-candle-boxes', emoji: '🕯️' },
          { name: 'Chocolate & Candy', slug: 'chocolate-boxes-packaging', emoji: '🍫' },
        ].map((ind, i) => (
          <a href={`/category/${ind.slug}`} class="industry-card-new reveal" style={`animation-delay: ${i * 0.06}s`}>
            <div class="ind-emoji">{ind.emoji}</div>
            <div class="ind-name">{ind.name}</div>
            <div class="ind-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="testimonials-new">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label testi-label">What Our Clients Say</div>
        <h2 class="testi-heading">Trusted by Australian Businesses</h2>
        <div class="gold-divider"></div>
      </div>
      <div class="testimonials-grid-new">
        {[
          {
            text: "ZEE Custom Boxes AU absolutely nailed our cosmetic packaging. The quality is exceptional — our customers always comment on how premium the boxes feel. The free design service saved us thousands!",
            name: "Sarah M.",
            role: "Beauty Brand Owner, Sydney",
            rating: 5,
          },
          {
            text: "We ordered custom bakery boxes for our patisserie and couldn't be happier. Fast turnaround, perfect quality, and the team was incredibly helpful throughout the entire process. Will definitely reorder.",
            name: "James T.",
            role: "Patisserie Owner, Melbourne",
            rating: 5,
          },
          {
            text: "As a startup, I was worried about minimum orders. ZEE had no minimums, helped with design at no cost, and delivered faster than expected. Highly recommend for any business needing custom packaging.",
            name: "Priya K.",
            role: "Wellness Brand Founder, Brisbane",
            rating: 5,
          },
        ].map((review, i) => (
          <div class="testi-card reveal" style={`animation-delay: ${i * 0.1}s`}>
            <div class="testi-quote-mark">"</div>
            <div class="testi-stars">{'★'.repeat(review.rating)}</div>
            <p class="testi-text">{review.text}</p>
            <div class="testi-author">
              <div class="testi-avatar">{review.name[0]}</div>
              <div>
                <div class="testi-name">{review.name}</div>
                <div class="testi-role">{review.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="testi-bottom reveal">
        <div class="testi-summary">
          <div class="testi-big-stars">★★★★★</div>
          <div>
            <div class="testi-avg">4.9 out of 5</div>
            <div class="testi-count">Based on 200+ verified reviews</div>
          </div>
        </div>
        <a href="/request-quote" class="btn btn-primary btn-lg">Join Our Happy Clients →</a>
      </div>
    </div>
  </section>

  <!-- ===================== QUOTE FORM ===================== -->
  <QuoteForm dark={true} />

  <!-- ===================== FAQ ===================== -->
  <section class="section bg-light">
    <div class="container container-sm">
      <div class="section-header reveal">
        <div class="section-label">FAQ</div>
        <h2>Frequently Asked Questions</h2>
        <div class="gold-divider"></div>
        <p>Have a question? Chances are we've answered it below. If not, <a href="/contact" class="faq-contact-link">contact us</a>.</p>
      </div>
      <div class="faq-list">
        {[
          { q: "What is the minimum order quantity?", a: "We have no minimum order quantity at ZEE Custom Boxes AU. You can order as few or as many units as your business needs, making us perfect for startups and established brands alike." },
          { q: "Is the design service really free?", a: "Yes! Our professional design service is completely free. Our expert designers will create your custom artwork, and you'll receive a 3D digital mockup for approval before we go to print — no design experience needed on your end." },
          { q: "How long does production take?", a: "Standard production typically takes 7–14 business days after artwork approval. We also offer express production options for urgent orders — contact us for details and pricing." },
          { q: "Do you ship across Australia?", a: "Yes, we deliver to all states and territories across Australia, including NSW, VIC, QLD, WA, SA, TAS, ACT, and NT. Fast, safe delivery is guaranteed to every location." },
          { q: "What materials do you use?", a: "We offer premium cardboard, kraft paper, rigid board, and corrugated cardboard. Finishing options include gloss lamination, matte lamination, spot UV, foil stamping, soft-touch coating, and embossing or debossing." },
          { q: "Can I see a sample before ordering?", a: "Absolutely. We provide digital 3D mockups before production so you can review every detail. Physical printed samples can also be arranged — contact our team for availability and pricing." },
          { q: "Do you offer eco-friendly packaging?", a: "Yes! We offer sustainable packaging options including recycled cardboard, FSC-certified kraft paper, and soy-based inks. Ask our team about our eco-friendly range when requesting a quote." },
          { q: "What types of custom boxes can you produce?", a: "We produce over 373 types of custom packaging including cosmetic boxes, food boxes, gift boxes, retail boxes, mailer boxes, tuck-end boxes, rigid boxes, sleeve boxes, display boxes, and much more. If you have something specific in mind, contact us — we'll make it happen." },
