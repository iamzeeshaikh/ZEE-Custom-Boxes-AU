---
interface Props {
  product: {
    name: string;
    slug: string;
    shortDescription: string;
    images: string[];
    categories: string[];
    primaryCategory: string;
    metaDescription?: string;
  };
  eager?: boolean;
}

const { product, eager = false } = Astro.props;

function stripHtml(html: string): string {
  return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

function catSlug(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();
}

const image = product.images[0] || '/images/placeholder.webp';
const excerpt = stripHtml(product.shortDescription || product.metaDescription || '').slice(0, 120);
---

<article class="product-card">
  <a href={`/product/${product.slug}`} class="product-card-link" aria-label={product.name}>
    <div class="product-card-img">
      <img
        src={image}
        alt={`${product.name} - ZEE Custom Boxes AU`}
        width="400"
        height="300"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        onerror="this.src='/images/placeholder.webp'"
      />
      <div class="product-card-overlay">
        <span class="product-card-cta">View Details →</span>
      </div>
    </div>
    <div class="product-card-body">
      {product.primaryCategory && (
        <a href={`/category/${catSlug(product.primaryCategory)}`} class="product-card-cat" onclick="event.stopPropagation()">
          {product.primaryCategory}
        </a>
      )}
      <h3 class="product-card-title">{product.name}</h3>
      {excerpt && <p class="product-card-excerpt">{excerpt}…</p>}
      <div class="product-card-footer">
        <span class="product-card-quote">Request a Quote</span>
        <svg class="product-card-arrow" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
    </div>
  </a>
</article>

<style>
.product-card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all var(--transition);
  border: 1px solid var(--color-border-light);
  height: 100%;
  display: flex;
  flex-direction: column;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
  border-color: var(--color-gold);
}

.product-card-link {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  color: inherit;
}

.product-card-img {
  position: relative;
  overflow: hidden;
  aspect-ratio: 4/3;
  background: var(--color-off-white);
}

.product-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.product-card:hover .product-card-img img {
  transform: scale(1.06);
}

.product-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(13,32,53,0.7) 0%, transparent 60%);
  display: flex;
  align-items: flex-end;
  padding: 1.25rem;
  opacity: 0;
  transition: opacity var(--transition);
}

.product-card:hover .product-card-overlay {
  opacity: 1;
}

.product-card-cta {
  color: var(--color-gold);
  font-weight: 600;
  font-size: 0.875rem;
  letter-spacing: 0.03em;
}

.product-card-body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 0.5rem;
}

.product-card-cat {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gold);
  text-decoration: none;
  transition: color 0.2s;
}

.product-card-cat:hover { color: var(--color-navy); }

.product-card-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--color-navy);
  line-height: 1.35;
  margin: 0;
}

.product-card-excerpt {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.product-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.75rem;
  border-top: 1px solid var(--color-border-light);
  margin-top: auto;
}

.product-card-quote {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-navy);
  letter-spacing: 0.02em;
}

.product-card-arrow {
  color: var(--color-gold);
  transition: transform var(--transition);
}

.product-card:hover .product-card-arrow {
  transform: translateX(4px);
}
</style>
