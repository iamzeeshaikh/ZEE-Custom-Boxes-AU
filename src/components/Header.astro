---
import { SITE, CTA } from '../config/site';
import categories from '../data/categories.json';
import products from '../data/products.json';
import locations from '../data/locations';

const statePages = locations.filter(l => l.type === 'state');
const cityPages  = locations.filter(l => l.type === 'city');

const productMap: Record<string, typeof products[0]> = {};
products.forEach(p => { productMap[p.slug] = p; });

const categoriesWithImages = categories.map(cat => ({
  ...cat,
  thumb: productMap[cat.products[0]]?.images?.[0] || '/images/placeholder.webp',
}));

// Products dropdown — top 9 categories
const featuredCats = categoriesWithImages.slice(0, 9);

// Industries dropdown — first 21 (3 rows × 7 cols)
const industryCats = categoriesWithImages.slice(0, 21);

// Box by Material — curated material-based categories
const materialSlugs = [
  'custom-kraft-boxes-packaging',
  'custom-cardboard-boxes',
  'custom-corrugated-boxes',
  'custom-rigid-boxes-packaging',
  'brown-boxes-packaging',
];
const materialCats = materialSlugs.map(slug => {
  const cat = categoriesWithImages.find(c => c.slug === slug);
  return cat!;
}).filter(Boolean);

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <!-- Top bar -->
  <div class="header-top">
    <div class="container">
      <div class="header-top-inner">
        <div class="header-contact">
          <a href={`tel:${SITE.phone}`} class="contact-link">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            {SITE.phone}
          </a>
          <a href={`mailto:${SITE.email}`} class="contact-link">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            {SITE.email}
          </a>
        </div>
        <div class="header-trust">
          <span>🇦🇺 Australian Business</span>
          <span>Free Design Service</span>
          <span>Fast Turnaround</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Nav wrap — mega panels are absolutely positioned here -->
  <div class="nav-wrap">
    <nav class="header-nav" role="navigation" aria-label="Main navigation">
      <div class="container">
        <div class="nav-inner">

          <!-- Logo -->
          <a href="/" class="logo" aria-label={SITE.name}>
            <div class="logo-mark"><span class="logo-z">Z</span></div>
            <div class="logo-text">
              <span class="logo-name">ZEE Custom Boxes</span>
              <span class="logo-sub">AU — Premium Packaging</span>
            </div>
          </a>

          <!-- Nav links -->
          <div class="nav-links" id="nav-links">

            <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Home</a>

            <!-- Products hover dropdown -->
            <div class="nav-item has-mega">
              <a href="/products" class="nav-link nav-trigger">
                Products <svg class="chev" width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </a>
              <div class="mega-panel">
                <div class="container">
                  <div class="mega-hdr">
                    <span class="mega-label">Popular Product Categories</span>
                    <a href="/products" class="mega-all">View All 373 Products →</a>
                  </div>
                  <div class="mega-grid cols-9">
                    {featuredCats.map(cat => (
                      <a href={`/category/${cat.slug}`} class="mega-item">
                        <div class="mega-thumb"><img src={cat.thumb} alt={cat.name} loading="lazy" /></div>
                        <span class="mega-name">{cat.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- By Material hover dropdown -->
            <div class="nav-item has-mega">
              <button class="nav-link nav-trigger">
                By Material <svg class="chev" width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </button>
              <div class="mega-panel">
                <div class="container">
                  <div class="mega-hdr">
                    <span class="mega-label">Shop by Material Type</span>
                    <a href="/products" class="mega-all">Browse All Products →</a>
                  </div>
                  <div class="mega-grid cols-5 material-grid">
                    {materialCats.map(cat => (
                      <a href={`/category/${cat.slug}`} class="mega-item material-item">
                        <div class="mega-thumb material-thumb"><img src={cat.thumb} alt={cat.name} loading="lazy" /></div>
                        <span class="mega-name">{cat.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Industries hover dropdown -->
            <div class="nav-item has-mega">
              <button class="nav-link nav-trigger">
                Industries <svg class="chev" width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </button>
              <div class="mega-panel">
                <div class="container">
                  <div class="mega-hdr">
                    <span class="mega-label">All Packaging Industries</span>
                    <a href="/products" class="mega-all">Browse All 373 Products →</a>
                  </div>
                  <div class="mega-grid cols-7">
                    {industryCats.map(cat => (
                      <a href={`/category/${cat.slug}`} class="mega-item">
                        <div class="mega-thumb"><img src={cat.thumb} alt={cat.name} loading="lazy" /></div>
                        <span class="mega-name">{cat.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Locations dropdown -->
            <div class="nav-item has-mega">
              <a href="/locations" class="nav-link nav-trigger">
                Locations <svg class="chev" width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
              </a>
              <div class="mega-panel loc-panel">
                <div class="container">
                  <div class="mega-hdr">
                    <span class="mega-label">We Deliver Across Australia</span>
                    <a href="/locations" class="mega-all">View All Locations →</a>
                  </div>
                  <div class="loc-dropdown-grid">
                    <div class="loc-dropdown-col">
                      <div class="loc-dropdown-title">By State</div>
                      <ul class="loc-dropdown-list">
                        {statePages.map(s => (
                          <li><a href={`/${s.slug}`}>{s.name}</a></li>
                        ))}
                        <li><a href="/custom-packaging-australia" class="loc-national-link">🇦🇺 All of Australia</a></li>
                      </ul>
                    </div>
                    <div class="loc-dropdown-col">
                      <div class="loc-dropdown-title">Major Cities</div>
                      <ul class="loc-dropdown-list loc-cities-list">
                        {cityPages.map(c => (
                          <li><a href={`/${c.slug}`}>{c.name}</a></li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div><!-- /nav-links -->

          <!-- CTA + hamburger -->
          <div class="nav-actions">
            <a href={CTA.quoteUrl} class="btn btn-primary btn-quote">Get Free Quote</a>
            <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
              <span></span><span></span><span></span>
            </button>
          </div>

        </div>
      </div>
    </nav>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay"></div>

<style>
/* ── Shell ─────────────────────────────────────────── */
.site-header { position: sticky; top: 0; z-index: 1000; background: #fff; }

/* Top bar */
.header-top { background: var(--color-navy-dark); padding: 0.45rem 0; }
.header-top-inner { display: flex; align-items: center; justify-content: space-between; }
.header-contact { display: flex; gap: 1.5rem; }
.contact-link {
  display: flex; align-items: center; gap: 0.4rem;
  color: rgba(255,255,255,0.8); font-size: 0.78rem;
  text-decoration: none; transition: color 0.2s;
}
.contact-link:hover { color: var(--color-gold); }
.header-trust { display: flex; gap: 1.5rem; color: rgba(255,255,255,0.6); font-size: 0.72rem; }
.header-trust span::before { content: '✓ '; color: var(--color-gold); }

/* Nav wrap — mega panels anchor here */
.nav-wrap { position: relative; background: #fff; box-shadow: 0 2px 0 rgba(0,0,0,0.06); }
.header-nav { background: transparent; }

.nav-inner {
  display: flex; align-items: center;
  gap: 0.25rem; padding: 0.85rem 0;
}

/* ── Logo ───────────────────────────────────────────── */
.logo { display: flex; align-items: center; gap: 0.7rem; text-decoration: none; flex-shrink: 0; }
.logo-mark {
  width: 40px; height: 40px;
  background: linear-gradient(135deg, var(--color-navy), var(--color-navy-dark));
  border-radius: 9px; display: flex; align-items: center; justify-content: center; position: relative;
}
.logo-mark::after { content: ''; position: absolute; inset: 2px; border: 1px solid rgba(201,168,76,0.4); border-radius: 7px; }
.logo-z { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: var(--color-gold); line-height: 1; }
.logo-text { display: flex; flex-direction: column; }
.logo-name { font-family: var(--font-display); font-size: 0.95rem; font-weight: 700; color: var(--color-navy); line-height: 1.2; }
.logo-sub { font-size: 0.6rem; font-weight: 500; color: var(--color-gold); letter-spacing: 0.08em; text-transform: uppercase; }

/* ── Nav links ──────────────────────────────────────── */
.nav-links { display: flex; align-items: center; gap: 0.05rem; margin-left: auto; }

.nav-link {
  display: flex; align-items: center; gap: 0.25rem;
  padding: 0.42rem 0.75rem;
  font-size: 0.865rem; font-weight: 500;
  color: var(--color-text);
  border-radius: var(--radius-sm);
  transition: all 0.18s;
  text-decoration: none; white-space: nowrap;
  background: none; border: none; cursor: pointer;
  font-family: var(--font-body);
}
.nav-link:hover { color: var(--color-navy); background: var(--color-off-white); }
.nav-link.active { color: var(--color-red); background: rgba(229,57,53,0.06); }

.chev { transition: transform 0.22s; flex-shrink: 0; opacity: 0.6; }

/* ── Nav item wrapper ───────────────────────────────── */
.nav-item { position: static; }

/* Hover state — driven by JS .is-open class */
.nav-item.is-open > .nav-link,
.nav-item.is-open > .nav-trigger { color: var(--color-red); background: rgba(229,57,53,0.06); }
.nav-item.is-open .chev { transform: rotate(180deg); opacity: 1; }
.nav-item.is-open .mega-panel {
  opacity: 1; visibility: visible;
  transform: translateY(0); pointer-events: auto;
  transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0s;
}

/* ── MEGA PANEL base ────────────────────────────────── */
.mega-panel {
  position: absolute;
  top: 100%; left: 0; right: 0;
  background: #fff;
  border-top: 3px solid var(--color-red);
  box-shadow: 0 18px 50px rgba(0,0,0,0.13);
  padding: 1.4rem 0 1.75rem;
  z-index: 999;
  opacity: 0; visibility: hidden;
  transform: translateY(-8px);
  transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
  pointer-events: none;
}

/* Panel header row */
.mega-hdr {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1.1rem; padding-bottom: 0.8rem;
  border-bottom: 1px solid var(--color-border);
}
.mega-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); }
.mega-all { font-size: 0.8rem; font-weight: 600; color: var(--color-red); text-decoration: none; transition: opacity 0.2s; }
.mega-all:hover { opacity: 0.72; }

/* ── Shared thumbnail grid ──────────────────────────── */
.mega-grid { display: grid; gap: 0.65rem; }
.cols-9 { grid-template-columns: repeat(9, 1fr); }
.cols-7 { grid-template-columns: repeat(7, 1fr); }
.cols-5 { grid-template-columns: repeat(5, 1fr); }

.mega-item {
  display: flex; flex-direction: column; align-items: center; gap: 0.45rem;
  text-decoration: none; border-radius: 8px;
  padding: 0.45rem 0.25rem 0.55rem;
  transition: background 0.18s;
}
.mega-item:hover { background: var(--color-off-white); }

.mega-thumb {
  width: 100%; aspect-ratio: 1;
  border-radius: 7px; overflow: hidden;
  background: var(--color-off-white);
  border: 1px solid var(--color-border-light);
}
.mega-thumb img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.32s;
}
.mega-item:hover .mega-thumb img { transform: scale(1.08); }

.mega-name {
  font-size: 0.67rem; font-weight: 600;
  color: var(--color-navy); text-align: center; line-height: 1.3;
}

/* Material dropdown — slightly bigger thumbs */
.material-grid { gap: 1rem; }
.material-item { padding: 0.6rem 0.4rem 0.7rem; }
.material-thumb { border-radius: 10px; border: 2px solid var(--color-border); }
.material-item:hover .material-thumb { border-color: var(--color-gold); }
.material-item .mega-name { font-size: 0.74rem; }

/* ── Locations dropdown ─────────────────────────────── */
.loc-panel { padding: 1.4rem 0 1.6rem; }
.loc-dropdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
.loc-dropdown-title {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--color-text-muted);
  margin-bottom: 0.7rem; padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--color-border);
}
.loc-dropdown-list { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.15rem 1rem; }
.loc-cities-list { grid-template-columns: 1fr 1fr; }
.loc-dropdown-list a {
  display: block; padding: 0.28rem 0.4rem;
  font-size: 0.82rem; color: var(--color-text);
  text-decoration: none; border-radius: 4px;
  transition: background 0.15s, color 0.15s;
}
.loc-dropdown-list a:hover { background: var(--color-off-white); color: var(--color-navy); }
.loc-national-link { color: var(--color-navy) !important; font-weight: 600; }

/* ── Nav actions ────────────────────────────────────── */
.nav-actions { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; margin-left: 0.5rem; }
.btn-quote { padding: 0.58rem 1.2rem; font-size: 0.875rem; }

/* Hamburger */
.nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 0.5rem; border-radius: var(--radius-sm); }
.nav-toggle span { display: block; width: 22px; height: 2px; background: var(--color-navy); border-radius: 2px; transition: all 0.3s; }

/* Overlay */
.nav-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 998; }

/* ── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 1280px) {
  .cols-9 { grid-template-columns: repeat(5, 1fr); }
  .cols-7 { grid-template-columns: repeat(5, 1fr); }
}
@media (max-width: 1080px) {
  .header-trust { display: none; }
  .cols-9 { grid-template-columns: repeat(4, 1fr); }
  .cols-7 { grid-template-columns: repeat(4, 1fr); }
  .cols-5 { grid-template-columns: repeat(4, 1fr); }
}

@media (max-width: 768px) {
  .header-top { display: none; }
  .nav-toggle { display: flex; }

  .nav-links {
    position: fixed; top: 0; right: -100%; bottom: 0;
    width: min(300px, 88vw); background: #fff;
    flex-direction: column; align-items: flex-start;
    padding: 4.5rem 1rem 2rem; gap: 0.1rem;
    z-index: 1001; transition: right 0.3s ease;
    overflow-y: auto; box-shadow: var(--shadow-xl); margin-left: 0;
  }
  .nav-links.open { right: 0; }
  .nav-overlay.active { display: block; }
  .nav-link { width: 100%; }

  /* Mobile: panels are inline, toggle open class */
  .mega-panel {
    position: static; border-top: none; box-shadow: none;
    padding: 0.25rem 0 0.5rem 0.5rem;
    opacity: 1; visibility: visible; transform: none;
    display: none; pointer-events: auto;
  }
  .nav-item.m-open .mega-panel { display: block; }
  .nav-item.m-open > .nav-link,
  .nav-item.m-open > .nav-trigger { color: var(--color-red); background: rgba(229,57,53,0.06); }
  .nav-item.m-open .chev { transform: rotate(180deg); }

  .mega-hdr { display: none; }
  .cols-9, .cols-7, .cols-5 { grid-template-columns: repeat(2, 1fr); gap: 0.3rem; }
  .mega-item { flex-direction: row; align-items: center; gap: 0.5rem; padding: 0.35rem 0.4rem; }
  .mega-thumb { width: 34px; height: 34px; aspect-ratio: 1; flex-shrink: 0; border-radius: 5px; }
  .mega-name { font-size: 0.74rem; text-align: left; }

  /* Locations on mobile */
  .loc-dropdown-grid { grid-template-columns: 1fr; gap: 1rem; }
  .loc-dropdown-list { grid-template-columns: 1fr 1fr; }
}
</style>

<script>
  /* ── Mobile hamburger ── */
  const navToggle  = document.getElementById('nav-toggle');
  const navLinksEl = document.getElementById('nav-links');
  const overlay    = document.getElementById('nav-overlay');

  navToggle?.addEventListener('click', () => {
    const open = navLinksEl?.classList.toggle('open');
    overlay?.classList.toggle('active', open);
  });
  overlay?.addEventListener('click', () => {
    navLinksEl?.classList.remove('open');
    overlay?.classList.remove('active');
  });

  /* ── Desktop: JS-managed hover with grace-period timer ──
     Pure CSS :hover loses the menu when the cursor crosses
     the padding gap between the nav button and the panel.
     This approach uses mouseenter/mouseleave + a 150ms timer
     so the panel stays open while the cursor travels down.
  ── */
  document.querySelectorAll<HTMLElement>('.nav-item.has-mega').forEach(item => {
    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    function openPanel() {
      if (window.innerWidth < 769) return;
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      // Close any other open panels first
      document.querySelectorAll('.nav-item.has-mega.is-open').forEach(other => {
        if (other !== item) other.classList.remove('is-open');
      });
      item.classList.add('is-open');
    }

    function scheduleClose() {
      if (window.innerWidth < 769) return;
      closeTimer = setTimeout(() => {
        item.classList.remove('is-open');
        closeTimer = null;
      }, 150);
    }

    // Open when cursor enters the nav item (button area)
    item.addEventListener('mouseenter', openPanel);
    // Start close timer when cursor leaves the nav item
    item.addEventListener('mouseleave', scheduleClose);

    // Cancel close if cursor re-enters the panel itself
    const panel = item.querySelector<HTMLElement>('.mega-panel');
    panel?.addEventListener('mouseenter', () => {
      if (window.innerWidth < 769) return;
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    });
    panel?.addEventListener('mouseleave', scheduleClose);
  });

  // Close all panels when clicking outside
  document.addEventListener('click', e => {
    if (!(e.target as HTMLElement).closest('.nav-item.has-mega')) {
      document.querySelectorAll('.nav-item.has-mega.is-open').forEach(item => {
        item.classList.remove('is-open');
      });
    }
  });

  /* ── Mobile tap-to-expand ── */
  document.querySelectorAll<HTMLElement>('.nav-item.has-mega .nav-trigger').forEach(btn => {
    btn.addEventListener('click', e => {
      if (window.innerWidth >= 769) return;
      e.preventDefault();
      btn.closest('.nav-item')?.classList.toggle('m-open');
    });
  });
</script>
